#!/bin/sh
# deploy/iso/auto/config — live-build configuration for the NetFirewall
# appliance ISO (Debian 13 / trixie, amd64).
#
# Run as: cd deploy/iso && lb config (lb reads auto/config automatically).
#
# Produces a hybrid ISO that is BOTH:
#   * a live appliance you can boot directly (or run as a VM), and
#   * a bare-metal installer (--debian-installer live + preseed) that lays the
#     same live filesystem to disk.
#
# Everything needed is embedded so the install works fully OFFLINE: the
# NetFirewall .deb (dropped into config/packages.chroot by CI) plus every OS
# dependency from the package-lists is pulled into the squashfs at build time.
set -e

lb config noauto \
    --mode debian \
    --distribution trixie \
    --architecture amd64 \
    --archive-areas "main contrib non-free-firmware" \
    --binary-images iso-hybrid \
    --debian-installer live \
    --debian-installer-gui false \
    --apt-indices false \
    --apt-recommends false \
    --memtest none \
    --iso-application "NetFirewall" \
    --iso-publisher "NetFirewall Project" \
    --iso-volume "NetFirewall trixie amd64" \
    --bootappend-live "boot=live components quiet splash hostname=netfirewall username=root noeject" \
    --bootappend-install "auto=true priority=critical" \
    "${@}"

# ── BIOS boot-menu branding (isolinux) ──────────────────────────────────────
# live-build uses config/bootloaders/<loader> INSTEAD of its stock theme when
# the directory exists, so a partial overlay would break the menu. Clone the
# stock theme from the build host and patch title + splash. Runs on every
# `lb config` (idempotent — always re-cloned from stock); the clone is a
# build-host artifact and is gitignored. The EFI (GRUB) menu picks up the same
# splash.png plus its own colors from config/bootloaders/grub-pc/config.cfg.
STOCK_ISOLINUX=/usr/share/live/build/bootloaders/isolinux
if [ -d "${STOCK_ISOLINUX}" ]; then
    rm -rf config/bootloaders/isolinux
    cp -a "${STOCK_ISOLINUX}" config/bootloaders/isolinux
    # Pre-rendered 640x480 splash (see branding/) — no rsvg/fontconfig needed
    # at build time, unlike the stock splash.svg.
    rm -f config/bootloaders/isolinux/splash.svg
    cp branding/splash.png config/bootloaders/isolinux/splash.png
    for f in config/bootloaders/isolinux/menu.cfg \
             config/bootloaders/isolinux/stdmenu.cfg; do
        if [ -f "${f}" ]; then
            sed -i 's/^menu title .*/menu title NetFirewall appliance/' "${f}"
        fi
    done
else
    echo "W: ${STOCK_ISOLINUX} not found — BIOS menu keeps the stock Debian theme." >&2
fi

# Notes on the choices:
#   --archive-areas non-free-firmware  → real NIC / wifi firmware on the media so
#                                        the appliance actually sees its ports.
#   --debian-installer live            → the d-i variant that installs THIS live
#                                        filesystem to disk (what the operator
#                                        wants for bare metal), preseeded.
#   --apt-recommends false             → keep the image lean; we Recommends:
#                                        deliberately and pull what we want via
#                                        the package-list.
#   --apt-indices false                → don't ship apt indices (offline image).
#
# Explicitly NOT set / NOT installed (see package-lists too):
#   * no network-manager / netplan.io  — we use ifupdown (DebianInterfacesConfigService).
#   * no cloud-init                     — this is an appliance, not a cloud image.
#   * no dotnet-runtime / Microsoft APT — the .deb is self-contained.
#   * no desktop task                   — headless appliance.
