#!/bin/bash
#
# /etc/update-motd.d/10-netfirewall — dynamic MOTD, executed by pam_motd via
# run-parts on every console / SSH login (output lands in /run/motd.dynamic).
#
# Shipped by the netfirewall .deb (see deploy/debian/rules + netfirewall.install);
# postinst restores the execute bit dh_fixperms strips from files under /etc.
#
# Fail-soft on purpose: a broken status probe must never break the login
# banner, so every probe tolerates failure. No `set -e`.

# ── logo (quoted heredoc: backslashes + backtick in the art stay literal) ──
printf '\033[1;32m'
cat <<'ART'
 _   _      _   _____ _                        _ _
| \ | | ___| |_|  ___(_)_ __ _____      ____ _| | |
|  \| |/ _ \ __| |_  | | '__/ _ \ \ /\ / / _` | | |
| |\  |  __/ |_|  _| | | | |  __/\ V  V / (_| | | |
|_| \_|\___|\__|_|   |_|_|  \___| \_/\_/ \__,_|_|_|
ART
printf '\033[0m'

ver=$(dpkg-query -W -f='${Version}' netfirewall 2>/dev/null) || ver=""
printf '  \033[2mNetFirewall appliance%s — %s\033[0m\n\n' \
    "${ver:+ v$ver}" "$(uname -sr 2>/dev/null)"

# ── unit states, colorized ──
unit_state() {
    local s
    s=$(systemctl is-active "$1" 2>/dev/null) || s=inactive
    case "$s" in
        active)   printf '\033[32m%s\033[0m' "$s" ;;
        inactive) printf '\033[2m%s\033[0m'  "$s" ;;
        *)        printf '\033[31m%s\033[0m' "$s" ;;
    esac
}
printf '  daemon: %s   web: %s   dhcp: %s   postgres: %s\n' \
    "$(unit_state netfirewall-daemon)" \
    "$(unit_state netfirewall-web)" \
    "$(unit_state netfirewall-dhcp)" \
    "$(unit_state postgresql)"

# ── web UI address(es) ──
addrs=$(ip -o -4 addr show scope global 2>/dev/null \
    | awk '{print $2" "$4}' \
    | grep -vE '^(lo|wg|tun|tap|docker|veth|br-)') || addrs=""
if [[ -n "$addrs" ]]; then
    while read -r iface cidr; do
        printf '  Web UI: \033[1mhttps://%s/\033[0m  (%s)\n' "${cidr%%/*}" "$iface"
    done <<<"$addrs"
else
    printf '  \033[33mNo network address yet (waiting for DHCP).\033[0m\n'
fi

printf '\n  Console admin: \033[1mnetfirewall-tui\033[0m    Health check: \033[1mnetfirewall-doctor\033[0m\n\n'
