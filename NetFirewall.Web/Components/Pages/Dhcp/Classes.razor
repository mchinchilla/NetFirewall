@page "/dhcp/classes"
@rendermode InteractiveServer
@using System.Net
@using NetFirewall.Models.Dhcp
@using NetFirewall.Services.Dhcp
@inject IDhcpAdminService DhcpService

<PageTitle>Client Classes - NetFirewall</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">Client Classes</h1>
            <p class="text-gray-600 dark:text-gray-400 mt-1">Classify clients for conditional DHCP configuration</p>
        </div>
        <button @onclick="ShowAddModal" class="btn-primary">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Class
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
            <div class="flex items-center gap-2 text-red-700 dark:text-red-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@_errorMessage</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4">
            <div class="flex items-center gap-2 text-green-700 dark:text-green-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>@_successMessage</span>
            </div>
        </div>
    }

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="stat-card">
            <p class="stat-label">Total Classes</p>
            <p class="stat-value">@_classes.Count</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Enabled</p>
            <p class="stat-value text-green-600">@_classes.Count(c => c.Enabled)</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">PXE Classes</p>
            <p class="stat-value text-blue-600">@_classes.Count(c => !string.IsNullOrEmpty(c.BootFilename))</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Match Types</p>
            <p class="stat-value">@_classes.Select(c => c.MatchType).Distinct().Count()</p>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="card">
        <div class="card-body py-3">
            <div class="flex items-center gap-4">
                <div class="flex-1">
                    <input type="text" class="form-input" placeholder="Search by name, match value, or boot file..." @bind="_searchTerm" @bind:event="oninput" />
                </div>
                <div class="flex items-center gap-2">
                    <label class="text-sm text-gray-600 dark:text-gray-400">Show:</label>
                    <select class="form-select w-auto" @bind="_filterStatus">
                        <option value="all">All Classes</option>
                        <option value="enabled">Enabled Only</option>
                        <option value="disabled">Disabled Only</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Classes Table -->
    <div class="card">
        <div class="overflow-x-auto">
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Match Type</th>
                        <th>Match Value</th>
                        <th>Boot File</th>
                        <th>Next Server</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th class="w-24">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cls in FilteredClasses)
                    {
                        <tr>
                            <td class="font-medium">@cls.Name</td>
                            <td>
                                <span class="badge-info">@FormatMatchType(cls.MatchType)</span>
                            </td>
                            <td class="font-mono text-sm">@cls.MatchValue</td>
                            <td class="text-sm">@(cls.BootFilename ?? "-")</td>
                            <td class="font-mono text-sm">@(cls.NextServer?.ToString() ?? "-")</td>
                            <td>@cls.Priority</td>
                            <td>
                                @if (cls.Enabled)
                                {
                                    <span class="badge-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="badge-danger">Disabled</span>
                                }
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <button class="btn-icon text-blue-400 hover:text-blue-600" title="Edit" @onclick="() => ShowEditModal(cls)">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </button>
                                    <button class="btn-icon text-red-400 hover:text-red-600" title="Delete" @onclick="() => ShowDeleteModal(cls)">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!FilteredClasses.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-8 text-gray-500 dark:text-gray-400">
                                @if (_classes.Any())
                                {
                                    <span>No classes found matching your criteria.</span>
                                }
                                else
                                {
                                    <div class="py-4">
                                        <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                        </svg>
                                        <p class="mb-3">No Client Classes Configured</p>
                                        <button class="btn-primary" @onclick="ShowAddModal">
                                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                            </svg>
                                            Add First Class
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Add/Edit Modal *@
@if (_showModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fade-in">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden max-h-[90vh] overflow-y-auto">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-gray-50 to-white dark:from-gray-800 dark:to-gray-750">
                <h3 class="text-lg font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">
                    @(_editId.HasValue ? "Edit Client Class" : "Add Client Class")
                </h3>
            </div>
            <div class="px-6 py-5 space-y-5">
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3">
                        <p class="text-sm text-red-700 dark:text-red-300">@_modalError</p>
                    </div>
                }
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="form-label">Name <span class="text-red-500">*</span></label>
                        <input type="text" class="form-input" @bind="_form.Name" placeholder="PXE BIOS Clients" />
                    </div>
                    <div>
                        <label class="form-label">Priority</label>
                        <input type="number" class="form-input" @bind="_form.Priority" />
                        <p class="text-xs text-gray-500 mt-1">Lower = higher priority</p>
                    </div>
                </div>

                <div>
                    <label class="form-label">Match Type <span class="text-red-500">*</span></label>
                    <select class="form-input" @bind="_form.MatchType">
                        <option value="vendor_class">Vendor Class (Option 60)</option>
                        <option value="user_class">User Class (Option 77)</option>
                        <option value="mac_prefix">MAC Prefix</option>
                        <option value="hardware_type">Hardware Type</option>
                        <option value="client_id">Client ID (Option 61)</option>
                        <option value="hostname">Hostname (Option 12)</option>
                        <option value="option">DHCP Option</option>
                        <option value="relay_agent">Relay Agent (Option 82)</option>
                    </select>
                </div>

                <div>
                    <label class="form-label">Match Value <span class="text-red-500">*</span></label>
                    <input type="text" class="form-input font-mono" @bind="_form.MatchValue" placeholder="@GetMatchValueHint(_form.MatchType)" />
                    <p class="text-xs text-gray-500 mt-1">@GetMatchValueDescription(_form.MatchType)</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="form-label">Next Server (TFTP)</label>
                        <input type="text" class="form-input font-mono" @bind="_form.NextServer" placeholder="192.168.1.1" />
                    </div>
                    <div>
                        <label class="form-label">Boot Filename</label>
                        <input type="text" class="form-input" @bind="_form.BootFilename" placeholder="pxelinux.0" />
                    </div>
                </div>

                <div>
                    <label class="form-label">Options Override (JSON)</label>
                    <textarea class="form-input font-mono text-sm" rows="3" @bind="_form.Options" placeholder='{"dns": ["1.1.1.1"], "domain": "pxe.local"}'></textarea>
                    <p class="text-xs text-gray-500 mt-1">Override DHCP options for matching clients</p>
                </div>

                <div class="flex items-center gap-3">
                    <input type="checkbox" class="form-checkbox" id="classEnabled" @bind="_form.Enabled" />
                    <label for="classEnabled" class="text-sm text-gray-700 dark:text-gray-300">Enable Class</label>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 flex justify-end gap-3">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary" @onclick="SaveClass" disabled="@_saving">
                    @if (_saving)
                    {
                        <svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@* Delete Confirm Modal *@
@if (_showDeleteModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fade-in">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">Confirm Delete</h3>
            </div>
            <div class="px-6 py-5">
                <p class="text-gray-600 dark:text-gray-400">
                    Are you sure you want to delete the class <span class="font-medium text-gray-900 dark:text-white">"@_deleteClass?.Name"</span>?
                </p>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 flex justify-end gap-3">
                <button class="btn-secondary" @onclick="() => _showDeleteModal = false">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<DhcpClass> _classes = [];

    private string _searchTerm = "";
    private string _filterStatus = "all";

    // Modal state
    private bool _showModal = false;
    private bool _showDeleteModal = false;
    private Guid? _editId = null;
    private ClassFormModel _form = new();
    private string? _modalError = null;
    private bool _saving = false;

    // Delete
    private DhcpClass? _deleteClass = null;

    // Messages
    private string? _errorMessage = null;
    private string? _successMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private IEnumerable<DhcpClass> FilteredClasses => _classes
        .Where(c => _filterStatus == "all" ||
                    (_filterStatus == "enabled" && c.Enabled) ||
                    (_filterStatus == "disabled" && !c.Enabled))
        .Where(c => string.IsNullOrEmpty(_searchTerm) ||
                    c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    c.MatchValue.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (c.BootFilename?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(c => c.Priority).ThenBy(c => c.Name);

    private async Task LoadDataAsync()
    {
        try
        {
            _classes = await DhcpService.GetClassesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading classes: {ex.Message}";
        }
    }

    private void ShowAddModal()
    {
        _editId = null;
        _form = new ClassFormModel();
        _modalError = null;
        _showModal = true;
        ClearMessages();
    }

    private void ShowEditModal(DhcpClass cls)
    {
        _editId = cls.Id;
        _form = new ClassFormModel
        {
            Name = cls.Name,
            MatchType = cls.MatchType,
            MatchValue = cls.MatchValue,
            NextServer = cls.NextServer?.ToString() ?? "",
            BootFilename = cls.BootFilename ?? "",
            Options = cls.Options ?? "",
            Priority = cls.Priority,
            Enabled = cls.Enabled
        };
        _modalError = null;
        _showModal = true;
        ClearMessages();
    }

    private void CloseModal()
    {
        _showModal = false;
        _modalError = null;
    }

    private async Task SaveClass()
    {
        _modalError = null;

        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _modalError = "Name is required";
            return;
        }

        if (string.IsNullOrWhiteSpace(_form.MatchValue))
        {
            _modalError = "Match value is required";
            return;
        }

        IPAddress? nextServer = null;
        if (!string.IsNullOrWhiteSpace(_form.NextServer) && !IPAddress.TryParse(_form.NextServer, out nextServer))
        {
            _modalError = "Invalid next server IP address";
            return;
        }

        _saving = true;

        try
        {
            var dhcpClass = new DhcpClass
            {
                Name = _form.Name,
                MatchType = _form.MatchType,
                MatchValue = _form.MatchValue,
                NextServer = nextServer,
                BootFilename = string.IsNullOrWhiteSpace(_form.BootFilename) ? null : _form.BootFilename,
                Options = string.IsNullOrWhiteSpace(_form.Options) ? null : _form.Options,
                Priority = _form.Priority,
                Enabled = _form.Enabled
            };

            if (_editId.HasValue)
            {
                dhcpClass.Id = _editId.Value;
                await DhcpService.UpdateClassAsync(dhcpClass);
                _successMessage = $"Class '{dhcpClass.Name}' updated successfully";
            }
            else
            {
                await DhcpService.CreateClassAsync(dhcpClass);
                _successMessage = $"Class '{dhcpClass.Name}' created successfully";
            }

            _showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _modalError = $"Error saving class: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ShowDeleteModal(DhcpClass cls)
    {
        _deleteClass = cls;
        _showDeleteModal = true;
        ClearMessages();
    }

    private async Task ConfirmDelete()
    {
        if (_deleteClass == null) return;

        try
        {
            await DhcpService.DeleteClassAsync(_deleteClass.Id);
            _successMessage = $"Class '{_deleteClass.Name}' deleted successfully";
            _showDeleteModal = false;
            _deleteClass = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error deleting class: {ex.Message}";
            _showDeleteModal = false;
        }
    }

    private void ClearMessages()
    {
        _errorMessage = null;
        _successMessage = null;
    }

    private static string FormatMatchType(string matchType) => matchType switch
    {
        "vendor_class" => "Vendor Class",
        "user_class" => "User Class",
        "mac_prefix" => "MAC Prefix",
        "hardware_type" => "Hardware",
        "client_id" => "Client ID",
        "hostname" => "Hostname",
        "option" => "Option",
        "relay_agent" => "Relay Agent",
        _ => matchType
    };

    private static string GetMatchValueHint(string matchType) => matchType switch
    {
        "vendor_class" => "PXEClient:Arch:00000",
        "mac_prefix" => "00:11:22",
        "hostname" => "printer-*",
        "user_class" => "iPXE",
        _ => "Match value..."
    };

    private static string GetMatchValueDescription(string matchType) => matchType switch
    {
        "vendor_class" => "Vendor class identifier from DHCP Option 60",
        "user_class" => "User class identifier from DHCP Option 77",
        "mac_prefix" => "First bytes of MAC address (e.g., 00:11:22)",
        "hardware_type" => "Hardware type (1=Ethernet, 6=Token Ring)",
        "client_id" => "Client identifier from DHCP Option 61",
        "hostname" => "Client hostname pattern from Option 12",
        "option" => "Match on any DHCP option value",
        "relay_agent" => "Relay agent information from Option 82",
        _ => ""
    };

    private class ClassFormModel
    {
        public string Name { get; set; } = "";
        public string MatchType { get; set; } = "vendor_class";
        public string MatchValue { get; set; } = "";
        public string NextServer { get; set; } = "";
        public string BootFilename { get; set; } = "";
        public string Options { get; set; } = "";
        public int Priority { get; set; } = 100;
        public bool Enabled { get; set; } = true;
    }
}
