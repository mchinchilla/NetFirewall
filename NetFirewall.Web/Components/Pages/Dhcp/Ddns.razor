@page "/dhcp/ddns"
@rendermode InteractiveServer
@using System.Net
@using NetFirewall.Models.Dhcp
@using NetFirewall.Services.Dhcp
@inject IDhcpAdminService DhcpService

<PageTitle>Dynamic DNS - NetFirewall</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">Dynamic DNS</h1>
            <p class="text-gray-600 dark:text-gray-400 mt-1">Configure DHCP-driven DNS updates (RFC 2136)</p>
        </div>
        <button @onclick="ShowAddModal" class="btn-primary">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add DDNS Config
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
            <div class="flex items-center gap-2 text-red-700 dark:text-red-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@_errorMessage</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4">
            <div class="flex items-center gap-2 text-green-700 dark:text-green-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>@_successMessage</span>
            </div>
        </div>
    }

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="stat-card">
            <p class="stat-label">Total Configs</p>
            <p class="stat-value">@_configs.Count</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Enabled</p>
            <p class="stat-value text-green-600">@_configs.Count(c => c.Enabled)</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Forward Zones</p>
            <p class="stat-value text-blue-600">@_configs.Count(c => c.EnableForward)</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Reverse Zones</p>
            <p class="stat-value text-purple-600">@_configs.Count(c => c.EnableReverse)</p>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="card">
        <div class="card-body py-3">
            <div class="flex items-center gap-4">
                <div class="flex-1">
                    <input type="text" class="form-input" placeholder="Search by zone, DNS server, or TSIG key..." @bind="_searchTerm" @bind:event="oninput" />
                </div>
                <div class="flex items-center gap-2">
                    <label class="text-sm text-gray-600 dark:text-gray-400">Show:</label>
                    <select class="form-select w-auto" @bind="_filterStatus">
                        <option value="all">All Configs</option>
                        <option value="enabled">Enabled Only</option>
                        <option value="disabled">Disabled Only</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- DDNS Configs Table -->
    <div class="card">
        <div class="overflow-x-auto">
            <table class="table">
                <thead>
                    <tr>
                        <th>Scope</th>
                        <th>Forward Zone</th>
                        <th>Reverse Zone</th>
                        <th>DNS Server</th>
                        <th>TSIG Key</th>
                        <th>Status</th>
                        <th class="w-24">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var config in FilteredConfigs)
                    {
                        <tr>
                            <td class="font-medium">@GetScopeName(config)</td>
                            <td>@(config.ForwardZone ?? "-")</td>
                            <td>@(config.ReverseZone ?? "-")</td>
                            <td class="font-mono text-sm">@(config.DnsServer?.ToString() ?? "-"):@config.DnsPort</td>
                            <td class="text-sm">@(config.TsigKeyName ?? "-")</td>
                            <td>
                                @if (config.Enabled)
                                {
                                    <span class="badge-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="badge-danger">Disabled</span>
                                }
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <button class="btn-icon text-blue-400 hover:text-blue-600" title="Edit" @onclick="() => ShowEditModal(config)">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </button>
                                    <button class="btn-icon text-red-400 hover:text-red-600" title="Delete" @onclick="() => ShowDeleteModal(config)">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!FilteredConfigs.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-8 text-gray-500 dark:text-gray-400">
                                @if (_configs.Any())
                                {
                                    <span>No configs found matching your criteria.</span>
                                }
                                else
                                {
                                    <div class="py-4">
                                        <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        <p class="mb-3">No Dynamic DNS Configurations</p>
                                        <button class="btn-primary" @onclick="ShowAddModal">
                                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                            </svg>
                                            Add First Config
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Add/Edit Modal *@
@if (_showModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fade-in">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden max-h-[90vh] overflow-y-auto">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-gray-50 to-white dark:from-gray-800 dark:to-gray-750">
                <h3 class="text-lg font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">
                    @(_editId.HasValue ? "Edit DDNS Config" : "Add DDNS Config")
                </h3>
            </div>
            <div class="px-6 py-5 space-y-5">
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3">
                        <p class="text-sm text-red-700 dark:text-red-300">@_modalError</p>
                    </div>
                }

                <!-- Scope -->
                <div>
                    <label class="form-label">Scope</label>
                    <select class="form-input" @bind="_form.SubnetId">
                        <option value="">Global (All Subnets)</option>
                        @foreach (var subnet in _subnets)
                        {
                            <option value="@subnet.Id">@subnet.Name (@subnet.Network)</option>
                        }
                    </select>
                </div>

                <!-- Zone Settings -->
                <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
                    <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Zone Settings</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">Forward Zone</label>
                            <input type="text" class="form-input" @bind="_form.ForwardZone" placeholder="example.com" />
                        </div>
                        <div>
                            <label class="form-label">Reverse Zone</label>
                            <input type="text" class="form-input" @bind="_form.ReverseZone" placeholder="1.168.192.in-addr.arpa" />
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mt-3">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" class="form-checkbox" id="enableForward" @bind="_form.EnableForward" />
                            <label for="enableForward" class="text-sm text-gray-700 dark:text-gray-300">Enable Forward Updates (A/AAAA)</label>
                        </div>
                        <div class="flex items-center gap-3">
                            <input type="checkbox" class="form-checkbox" id="enableReverse" @bind="_form.EnableReverse" />
                            <label for="enableReverse" class="text-sm text-gray-700 dark:text-gray-300">Enable Reverse Updates (PTR)</label>
                        </div>
                    </div>
                </div>

                <!-- DNS Server -->
                <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
                    <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">DNS Server</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">DNS Server IP <span class="text-red-500">*</span></label>
                            <input type="text" class="form-input font-mono" @bind="_form.DnsServer" placeholder="192.168.1.1" />
                        </div>
                        <div>
                            <label class="form-label">Port</label>
                            <input type="number" class="form-input" @bind="_form.DnsPort" />
                        </div>
                    </div>
                </div>

                <!-- TSIG Authentication -->
                <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
                    <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">TSIG Authentication</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">Key Name</label>
                            <input type="text" class="form-input" @bind="_form.TsigKeyName" placeholder="ddns-key" />
                        </div>
                        <div>
                            <label class="form-label">Algorithm</label>
                            <select class="form-input" @bind="_form.TsigAlgorithm">
                                <option value="hmac-sha256">HMAC-SHA256 (Recommended)</option>
                                <option value="hmac-sha512">HMAC-SHA512</option>
                                <option value="hmac-sha1">HMAC-SHA1</option>
                                <option value="hmac-md5.sig-alg.reg.int">HMAC-MD5 (Legacy)</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Key Secret (Base64)</label>
                        <input type="password" class="form-input font-mono" @bind="_form.TsigKeySecret" placeholder="Base64 encoded secret..." />
                    </div>
                </div>

                <!-- Update Policy -->
                <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
                    <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Update Policy</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">Update Style</label>
                            <select class="form-input" @bind="_form.UpdateStyle">
                                <option value="standard">Standard</option>
                                <option value="interim">Interim (Client FQDN)</option>
                                <option value="none">None</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">TTL (seconds)</label>
                            <input type="number" class="form-input" @bind="_form.Ttl" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Conflict Resolution</label>
                        <select class="form-input" @bind="_form.ConflictResolution">
                            <option value="check-with-dhcid">Check with DHCID</option>
                            <option value="no-check">No Check (Always Update)</option>
                            <option value="fail-on-conflict">Fail on Conflict</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mt-3">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" class="form-checkbox" id="overrideClient" @bind="_form.OverrideClientUpdate" />
                            <label for="overrideClient" class="text-sm text-gray-700 dark:text-gray-300">Override client hostname</label>
                        </div>
                        <div class="flex items-center gap-3">
                            <input type="checkbox" class="form-checkbox" id="allowClient" @bind="_form.AllowClientUpdates" />
                            <label for="allowClient" class="text-sm text-gray-700 dark:text-gray-300">Allow client updates</label>
                        </div>
                    </div>
                </div>

                <!-- Enabled -->
                <div class="flex items-center gap-3">
                    <input type="checkbox" class="form-checkbox" id="ddnsEnabled" @bind="_form.Enabled" />
                    <label for="ddnsEnabled" class="text-sm text-gray-700 dark:text-gray-300">Enable DDNS Config</label>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 flex justify-end gap-3">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary" @onclick="SaveConfig" disabled="@_saving">
                    @if (_saving)
                    {
                        <svg class="animate-spin w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@* Delete Confirm Modal *@
@if (_showDeleteModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fade-in">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">Confirm Delete</h3>
            </div>
            <div class="px-6 py-5">
                <p class="text-gray-600 dark:text-gray-400">
                    Are you sure you want to delete the DDNS config for <span class="font-medium text-gray-900 dark:text-white">@GetScopeName(_deleteConfig)</span>?
                </p>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 flex justify-end gap-3">
                <button class="btn-secondary" @onclick="() => _showDeleteModal = false">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<DdnsConfig> _configs = [];
    private IReadOnlyList<DhcpSubnet> _subnets = [];

    private string _searchTerm = "";
    private string _filterStatus = "all";

    // Modal state
    private bool _showModal = false;
    private bool _showDeleteModal = false;
    private Guid? _editId = null;
    private DdnsFormModel _form = new();
    private string? _modalError = null;
    private bool _saving = false;

    // Delete
    private DdnsConfig? _deleteConfig = null;

    // Messages
    private string? _errorMessage = null;
    private string? _successMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private IEnumerable<DdnsConfig> FilteredConfigs => _configs
        .Where(c => _filterStatus == "all" ||
                    (_filterStatus == "enabled" && c.Enabled) ||
                    (_filterStatus == "disabled" && !c.Enabled))
        .Where(c => string.IsNullOrEmpty(_searchTerm) ||
                    (c.ForwardZone?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.ReverseZone?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.DnsServer?.ToString().Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.TsigKeyName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    private async Task LoadDataAsync()
    {
        try
        {
            var configsTask = DhcpService.GetDdnsConfigsAsync();
            var subnetsTask = DhcpService.GetSubnetsAsync();

            await Task.WhenAll(configsTask, subnetsTask);

            _configs = await configsTask;
            _subnets = await subnetsTask;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private string GetScopeName(DdnsConfig? config)
    {
        if (config == null) return "Unknown";
        if (!config.SubnetId.HasValue) return "Global";
        var subnet = _subnets.FirstOrDefault(s => s.Id == config.SubnetId.Value);
        return subnet?.Name ?? "Unknown Subnet";
    }

    private void ShowAddModal()
    {
        _editId = null;
        _form = new DdnsFormModel();
        _modalError = null;
        _showModal = true;
        ClearMessages();
    }

    private void ShowEditModal(DdnsConfig config)
    {
        _editId = config.Id;
        _form = new DdnsFormModel
        {
            SubnetId = config.SubnetId,
            EnableForward = config.EnableForward,
            EnableReverse = config.EnableReverse,
            ForwardZone = config.ForwardZone ?? "",
            ReverseZone = config.ReverseZone ?? "",
            DnsServer = config.DnsServer?.ToString() ?? "",
            DnsPort = config.DnsPort,
            TsigKeyName = config.TsigKeyName ?? "",
            TsigKeySecret = config.TsigKeySecret ?? "",
            TsigAlgorithm = config.TsigAlgorithm,
            Ttl = config.Ttl,
            UpdateStyle = config.UpdateStyle,
            OverrideClientUpdate = config.OverrideClientUpdate,
            AllowClientUpdates = config.AllowClientUpdates,
            ConflictResolution = config.ConflictResolution,
            Enabled = config.Enabled
        };
        _modalError = null;
        _showModal = true;
        ClearMessages();
    }

    private void CloseModal()
    {
        _showModal = false;
        _modalError = null;
    }

    private async Task SaveConfig()
    {
        _modalError = null;

        if (string.IsNullOrWhiteSpace(_form.DnsServer) || !IPAddress.TryParse(_form.DnsServer, out var dnsServer))
        {
            _modalError = "A valid DNS server IP address is required";
            return;
        }

        _saving = true;

        try
        {
            var config = new DdnsConfig
            {
                SubnetId = _form.SubnetId,
                EnableForward = _form.EnableForward,
                EnableReverse = _form.EnableReverse,
                ForwardZone = string.IsNullOrWhiteSpace(_form.ForwardZone) ? null : _form.ForwardZone,
                ReverseZone = string.IsNullOrWhiteSpace(_form.ReverseZone) ? null : _form.ReverseZone,
                DnsServer = dnsServer,
                DnsPort = _form.DnsPort,
                TsigKeyName = string.IsNullOrWhiteSpace(_form.TsigKeyName) ? null : _form.TsigKeyName,
                TsigKeySecret = string.IsNullOrWhiteSpace(_form.TsigKeySecret) ? null : _form.TsigKeySecret,
                TsigAlgorithm = _form.TsigAlgorithm,
                Ttl = _form.Ttl,
                UpdateStyle = _form.UpdateStyle,
                OverrideClientUpdate = _form.OverrideClientUpdate,
                AllowClientUpdates = _form.AllowClientUpdates,
                ConflictResolution = _form.ConflictResolution,
                Enabled = _form.Enabled
            };

            if (_editId.HasValue)
            {
                config.Id = _editId.Value;
                await DhcpService.UpdateDdnsConfigAsync(config);
                _successMessage = "DDNS config updated successfully";
            }
            else
            {
                await DhcpService.CreateDdnsConfigAsync(config);
                _successMessage = "DDNS config created successfully";
            }

            _showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _modalError = $"Error saving config: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ShowDeleteModal(DdnsConfig config)
    {
        _deleteConfig = config;
        _showDeleteModal = true;
        ClearMessages();
    }

    private async Task ConfirmDelete()
    {
        if (_deleteConfig == null) return;

        try
        {
            await DhcpService.DeleteDdnsConfigAsync(_deleteConfig.Id);
            _successMessage = "DDNS config deleted successfully";
            _showDeleteModal = false;
            _deleteConfig = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error deleting config: {ex.Message}";
            _showDeleteModal = false;
        }
    }

    private void ClearMessages()
    {
        _errorMessage = null;
        _successMessage = null;
    }

    private class DdnsFormModel
    {
        public Guid? SubnetId { get; set; }
        public bool EnableForward { get; set; } = true;
        public bool EnableReverse { get; set; } = true;
        public string ForwardZone { get; set; } = "";
        public string ReverseZone { get; set; } = "";
        public string DnsServer { get; set; } = "";
        public int DnsPort { get; set; } = 53;
        public string TsigKeyName { get; set; } = "";
        public string TsigKeySecret { get; set; } = "";
        public string TsigAlgorithm { get; set; } = "hmac-sha256";
        public int Ttl { get; set; } = 300;
        public string UpdateStyle { get; set; } = "standard";
        public bool OverrideClientUpdate { get; set; }
        public bool AllowClientUpdates { get; set; }
        public string ConflictResolution { get; set; } = "check-with-dhcid";
        public bool Enabled { get; set; } = true;
    }
}
