@page "/dhcp/failover"
@rendermode InteractiveServer
@using NetFirewall.Services.Dhcp
@using System.Timers
@inject IDhcpAdminService DhcpService
@implements IDisposable

<PageTitle>DHCP Failover - NetFirewall</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">Failover Status</h1>
            <p class="text-gray-600 dark:text-gray-400 mt-1">DHCP failover peer status and health monitoring</p>
        </div>
        <div class="flex items-center gap-3">
            @if (_isRefreshing)
            {
                <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-primary-600"></div>
            }
            <div class="flex items-center gap-2">
                <label class="text-sm text-gray-600 dark:text-gray-400">Auto-refresh:</label>
                <button class="@(_autoRefresh ? "badge-success cursor-pointer" : "badge-danger cursor-pointer")" @onclick="ToggleAutoRefresh">
                    @(_autoRefresh ? "On (15s)" : "Off")
                </button>
            </div>
            <button class="btn-secondary" @onclick="RefreshDataAsync" disabled="@_isRefreshing">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Refresh
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
            <div class="flex items-center gap-2 text-red-700 dark:text-red-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@_errorMessage</span>
            </div>
        </div>
    }

    @if (_status == null)
    {
        <!-- No failover configured -->
        <div class="card">
            <div class="card-body text-center py-12">
                <svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Failover Not Configured</h3>
                <p class="text-gray-500 dark:text-gray-400">No DHCP failover peers are configured. Failover status will appear here once a peer is set up.</p>
            </div>
        </div>
    }
    else
    {
        <!-- Health Banner -->
        <div class="@(_status.IsHealthy
            ? "bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/10 border border-green-200 dark:border-green-800"
            : "bg-gradient-to-r from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/10 border border-red-200 dark:border-red-800") rounded-xl p-6">
            <div class="flex items-center gap-4">
                <div class="@(_status.IsHealthy
                    ? "w-14 h-14 bg-gradient-to-br from-green-400 to-emerald-600 shadow-green-500/25"
                    : "w-14 h-14 bg-gradient-to-br from-red-400 to-red-600 shadow-red-500/25") rounded-2xl flex items-center justify-center shadow-lg">
                    @if (_status.IsHealthy)
                    {
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    }
                    else
                    {
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    }
                </div>
                <div>
                    <h2 class="text-xl font-bold @(_status.IsHealthy ? "text-green-800 dark:text-green-200" : "text-red-800 dark:text-red-200")">
                        @(_status.IsHealthy ? "Failover Healthy" : "Failover Degraded")
                    </h2>
                    <p class="text-sm @(_status.IsHealthy ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400")">
                        Peer: @_status.PeerAddress
                    </p>
                </div>
            </div>
        </div>

        <!-- Status Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="stat-card">
                <p class="stat-label">Local State</p>
                <p class="stat-value text-sm">
                    <span class="@GetStateColorClass(_status.LocalState)">@_status.LocalState</span>
                </p>
            </div>
            <div class="stat-card">
                <p class="stat-label">Peer State</p>
                <p class="stat-value text-sm">
                    <span class="@GetStateColorClass(_status.PeerState)">@_status.PeerState</span>
                </p>
            </div>
            <div class="stat-card">
                <p class="stat-label">Role</p>
                <p class="stat-value text-sm">@_status.Role</p>
            </div>
            <div class="stat-card">
                <p class="stat-label">Last Contact</p>
                <p class="stat-value text-sm">
                    @if (_status.LastContact.HasValue)
                    {
                        @FormatTimeAgo(_status.LastContact.Value)
                    }
                    else
                    {
                        <span class="text-gray-400">Never</span>
                    }
                </p>
            </div>
        </div>

        <!-- Details Card -->
        <div class="card">
            <div class="card-header">
                <h2 class="text-lg font-semibold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">Failover Details</h2>
            </div>
            <div class="card-body">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-6 text-sm">
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">Peer Address</span>
                        <p class="font-mono font-medium text-gray-900 dark:text-white mt-1">@_status.PeerAddress</p>
                    </div>
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">Role</span>
                        <p class="font-medium text-gray-900 dark:text-white mt-1">@_status.Role</p>
                    </div>
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">Last Contact</span>
                        <p class="font-medium text-gray-900 dark:text-white mt-1">
                            @(_status.LastContact?.ToString("yyyy-MM-dd HH:mm:ss UTC") ?? "Never")
                        </p>
                    </div>
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">Local State</span>
                        <p class="mt-1">
                            <span class="@GetStateBadgeClass(_status.LocalState)">@_status.LocalState</span>
                        </p>
                    </div>
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">Peer State</span>
                        <p class="mt-1">
                            <span class="@GetStateBadgeClass(_status.PeerState)">@_status.PeerState</span>
                        </p>
                    </div>
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">Overall Health</span>
                        <p class="mt-1">
                            @if (_status.IsHealthy)
                            {
                                <span class="badge-success">Healthy</span>
                            }
                            else
                            {
                                <span class="badge-danger">Degraded</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DhcpFailoverStatus? _status;
    private string? _errorMessage;
    private bool _isRefreshing;
    private bool _autoRefresh = true;
    private Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        StartAutoRefresh();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _status = await DhcpService.GetFailoverStatusAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading failover status: {ex.Message}";
        }
    }

    private async Task RefreshDataAsync()
    {
        try
        {
            _isRefreshing = true;
            await InvokeAsync(StateHasChanged);

            await LoadDataAsync();

            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _isRefreshing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = new Timer(15000);
        _refreshTimer.Elapsed += async (sender, e) => await RefreshDataAsync();
        _refreshTimer.AutoReset = true;
        _refreshTimer.Start();
    }

    private void StopAutoRefresh()
    {
        _refreshTimer?.Stop();
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private void ToggleAutoRefresh()
    {
        _autoRefresh = !_autoRefresh;
        if (_autoRefresh)
            StartAutoRefresh();
        else
            StopAutoRefresh();
    }

    private static string GetStateColorClass(string state) => state switch
    {
        "Normal" => "text-green-600 dark:text-green-400",
        "CommunicationsInterrupted" => "text-yellow-600 dark:text-yellow-400",
        "PartnerDown" => "text-red-600 dark:text-red-400",
        "Startup" or "Recover" or "RecoverWait" or "RecoverDone" => "text-blue-600 dark:text-blue-400",
        _ => "text-gray-600 dark:text-gray-400"
    };

    private static string GetStateBadgeClass(string state) => state switch
    {
        "Normal" => "badge-success",
        "CommunicationsInterrupted" => "badge-warning",
        "PartnerDown" => "badge-danger",
        "Startup" or "Recover" or "RecoverWait" or "RecoverDone" => "badge-info",
        _ => "badge-info"
    };

    private static string FormatTimeAgo(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        if (elapsed.TotalSeconds < 60)
            return $"{(int)elapsed.TotalSeconds}s ago";
        if (elapsed.TotalMinutes < 60)
            return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24)
            return $"{(int)elapsed.TotalHours}h ago";
        return $"{(int)elapsed.TotalDays}d ago";
    }

    public void Dispose()
    {
        _refreshTimer?.Stop();
        _refreshTimer?.Dispose();
    }
}
