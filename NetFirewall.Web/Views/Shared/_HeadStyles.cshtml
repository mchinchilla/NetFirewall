@*
    <head>-time assets:
      - Tailwind-compiled stylesheet
      - site.js loaded synchronously so the pre-paint theme hydrator can run
        BEFORE the body parses (avoids FOUC when switching themes).
*@
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (async () => { await window.NetFw.hydrateBeforePaint(); })();
</script>
