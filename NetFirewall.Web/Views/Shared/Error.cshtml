@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="card max-w-2xl" style="animation: var(--animate-slide-up);">
    <h1 class="text-2xl font-semibold text-feedback-danger-fg">An error occurred</h1>
    <p class="mt-1 text-surface-fg-muted">Something went wrong while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-4 text-sm">
            <span class="font-medium">Request ID:</span>
            <code class="ml-1 rounded px-1.5 py-0.5 text-xs bg-surface-muted text-surface-fg">@Model.RequestId</code>
        </p>
    }

    <div class="mt-6 pt-4 border-t border-surface-border">
        <h3 class="text-sm font-semibold">Development mode</h3>
        <p class="mt-1 text-sm text-surface-fg-muted">
            Set <code class="rounded px-1 text-xs bg-surface-muted">ASPNETCORE_ENVIRONMENT=Development</code> and restart the app to see detailed error pages.
            Do not enable this in production.
        </p>
    </div>
</section>
