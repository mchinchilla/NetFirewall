@model NetFirewall.Web.Models.KpiCardViewModel
@{
    var deltaClass = Model.Trend switch
    {
        NetFirewall.Web.Models.DeltaTrend.Up   => "kpi-delta-up",
        NetFirewall.Web.Models.DeltaTrend.Down => "kpi-delta-down",
        _                                       => string.Empty
    };
}
<article class="kpi">
    <div class="flex items-start justify-between">
        <p class="kpi-label">@Model.Label</p>
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent-soft text-accent">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="@Model.IconPath" />
            </svg>
        </span>
    </div>
    <p class="kpi-value mt-3">
        @Model.Value
        @if (!string.IsNullOrEmpty(Model.ValueSuffix))
        {
            <span class="text-base font-normal text-surface-fg-muted">@Model.ValueSuffix</span>
        }
    </p>
    @if (!string.IsNullOrEmpty(Model.Delta) || !string.IsNullOrEmpty(Model.DeltaContext))
    {
        <p class="text-xs mt-1">
            @if (!string.IsNullOrEmpty(Model.Delta))
            {
                <span class="@deltaClass font-medium">@Model.Delta</span>
            }
            @if (!string.IsNullOrEmpty(Model.DeltaContext))
            {
                <span class="text-surface-fg-muted">@Model.DeltaContext</span>
            }
        </p>
    }
</article>
