@inject NetFirewall.Web.Auth.IAppInfoService AppInfo
@{
    var ip = Context.Connection.RemoteIpAddress?.ToString() ?? "—";
    if (ip == "::1") ip = "127.0.0.1 (loopback)";
    // Server boot epoch in ms — feeds the Alpine ticker so the clock + uptime
    // stay live without a server roundtrip.
    var startedMs = AppInfo.StartedAt.ToUnixTimeMilliseconds();
}

<div class="rounded-xl border p-4 text-xs"
     style="border-color: var(--surface-border); background-color: color-mix(in srgb, var(--surface-elevated) 70%, transparent);"
     x-data="runtimeMetrics(@startedMs)">

    <div class="flex items-center gap-2 mb-3 font-semibold" style="color: var(--surface-fg);">
        <svg class="h-4 w-4" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
        </svg>
        <span>System info</span>
    </div>

    <dl class="grid grid-cols-2 gap-x-4 gap-y-2" style="color: var(--surface-fg-muted);">
        <div class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3"/></svg>
            <dt class="sr-only">Client IP</dt>
            <dd class="font-mono" style="color: var(--surface-fg);">@ip</dd>
        </div>

        <div class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            <dt class="sr-only">Server time (live)</dt>
            <dd class="font-mono" style="color: var(--surface-fg);" x-text="clock"></dd>
        </div>

        <div class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5 9 9.75l3.75 3.75 6-6m0 0H15.75m3-0v3"/></svg>
            <dt class="sr-only">Uptime (live)</dt>
            <dd class="font-mono" style="color: var(--surface-fg);" x-text="uptime"></dd>
        </div>

        <div class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068"/></svg>
            <dt class="sr-only">Version</dt>
            <dd class="font-mono" style="color: var(--surface-fg);">v@(AppInfo.Version) · @AppInfo.Environment</dd>
        </div>
    </dl>
</div>
