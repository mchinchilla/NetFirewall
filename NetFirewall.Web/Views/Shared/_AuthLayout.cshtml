<!DOCTYPE html>
@inject NetFirewall.Services.Settings.IAppSettingsService AppSettings
@*
    Auth shell — two-column on lg+, single column stacked on smaller.
    Left: form (centered, capped at max-w-md). Right: brand panel (theme-tinted).
    No sidebar / topheader / drawer / confirm — those need an authenticated session.
*@
@{
    var authTheme = await AppSettings.GetStringAsync("appearance.default_theme");
    var authMode  = await AppSettings.GetStringAsync("appearance.default_mode");
    if (string.IsNullOrEmpty(authTheme)) authTheme = "boulder";
    if (string.IsNullOrEmpty(authMode))  authMode  = "light";
}
<html lang="en" class="h-full" data-theme="@authTheme" data-mode="@authMode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NetFirewall</title>
    @await Html.PartialAsync("_HeadStyles")
</head>
<body class="min-h-screen relative overflow-x-hidden" x-data>
    @await Html.PartialAsync("_BackgroundBlobs")

    <div class="grid min-h-screen lg:grid-cols-2">

        @* ---------- LEFT: form column ---------- *@
        <main class="flex flex-col px-6 py-8 sm:px-10">
            <div class="flex items-center gap-2 mb-10">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent text-accent-fg">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25 4.5 5.25v6c0 4.97 3.5 9.25 7.5 10.5 4-1.25 7.5-5.53 7.5-10.5v-6L12 2.25Z" />
                    </svg>
                </span>
                <span class="text-lg font-semibold tracking-tight">NetFirewall</span>
            </div>

            <div class="flex-1 flex items-center justify-center">
                <div class="w-full max-w-md" style="animation: var(--animate-slide-up);">
                    @RenderBody()
                </div>
            </div>

            <footer class="mt-10 text-center text-xs text-surface-fg-muted">
                NetFirewall &copy; @DateTime.UtcNow.Year · forward-only migrations · Argon2id · TOTP-gated
            </footer>
        </main>

        @* ---------- RIGHT: brand panel ---------- *@
        @await Html.PartialAsync("_AuthBrandPanel")
    </div>

    @await Html.PartialAsync("_Toasts")
    @await Html.PartialAsync("_Scripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
