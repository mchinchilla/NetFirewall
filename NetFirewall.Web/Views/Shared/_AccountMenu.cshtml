@inject NetFirewall.Services.Auth.IUserService UserSvc
@{
    // Pull the user fresh so display name + initials reflect the latest profile
    // edits without needing to log out/in. One small DB hit per page render.
    NetFirewall.Models.Auth.User? me = null;
    if (User.Identity?.IsAuthenticated == true &&
        Guid.TryParse(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier), out var meId))
    {
        try { me = await UserSvc.GetByIdAsync(meId); } catch { /* tolerate DB hiccup */ }
    }

    var username = User.Identity?.Name ?? "?";
    var displayName = me?.EffectiveDisplayName ?? username;
    var initials    = me?.Initials ?? FallbackInitials(username);
    var role        = User.FindFirstValue(System.Security.Claims.ClaimTypes.Role) ?? "";
    var email       = me?.Email;
}

@functions {
    static string FallbackInitials(string username)
    {
        var parts = username.Split(new[] { ' ', '.', '_', '-' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
        return username.Length > 0 ? username[..1].ToUpperInvariant() : "?";
    }
}

<div class="relative" x-data="{ open: false }">
    <button type="button"
            class="flex items-center gap-2 rounded-full p-0.5 pr-2 transition hover:shadow-sm bg-surface-muted"
            @@click="open = !open"
            aria-label="Account menu"
            title="@username">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full text-xs font-semibold bg-accent text-accent-fg">@initials</span>
        <span class="hidden sm:inline text-sm font-medium">@displayName</span>
        <svg class="h-4 w-4 hidden sm:inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
    </button>

    <div x-cloak x-show="open" @@click.outside="open = false"
         x-transition.opacity.duration.150ms
         class="absolute right-0 mt-2 w-72 origin-top-right rounded-xl border shadow-lg overflow-hidden bg-surface-elevated border-surface-border">
        <div class="px-4 py-3 border-b border-surface-border">
            <div class="flex items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-full text-sm font-semibold shrink-0 bg-accent text-accent-fg">@initials</span>
                <div class="min-w-0">
                    <p class="text-sm font-semibold truncate">@displayName</p>
                    <p class="text-xs font-mono truncate text-surface-fg-muted">@username</p>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(email))
            {
                <p class="text-xs mt-2 truncate text-surface-fg-muted">@email</p>
            }
            <p class="text-xs mt-2">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] uppercase tracking-wider font-semibold bg-accent-soft text-accent">@role</span>
            </p>
        </div>

        <ul class="py-1.5 text-sm">
            <li>
                <a href="/account/profile" class="flex items-center gap-2 px-4 py-2 hover:opacity-80 text-surface-fg">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
                    Profile
                </a>
            </li>
            <li>
                <a href="/account/security" class="flex items-center gap-2 px-4 py-2 hover:opacity-80 text-surface-fg">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
                    Security &amp; sessions
                </a>
            </li>
        </ul>

        <form action="/logout" method="post" class="border-t border-surface-border">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm hover:opacity-80 text-surface-fg">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75"/></svg>
                Sign out
            </button>
        </form>
    </div>
</div>
