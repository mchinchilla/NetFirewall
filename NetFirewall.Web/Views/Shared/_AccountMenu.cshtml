@{
    var username = User.Identity?.Name ?? "?";
    var role = User.FindFirstValue(System.Security.Claims.ClaimTypes.Role) ?? "";
    var initials = string.Concat(username.Split(' ', '.', '_', '-')
        .Where(p => p.Length > 0).Take(2).Select(p => char.ToUpperInvariant(p[0])));
    if (string.IsNullOrEmpty(initials)) initials = username.Length > 0 ? username[..1].ToUpperInvariant() : "?";
}

<div class="relative" x-data="{ open: false }">
    <button type="button"
            class="flex items-center gap-2 rounded-full p-0.5 pr-2 transition hover:shadow-sm"
            style="background-color: var(--surface-muted);"
            @@click="open = !open"
            aria-label="Account menu">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full text-xs font-semibold"
              style="background-color: var(--accent); color: var(--accent-fg);">@initials</span>
        <span class="hidden sm:inline text-sm font-medium">@username</span>
        <svg class="h-4 w-4 hidden sm:inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
    </button>

    <div x-cloak x-show="open" @@click.outside="open = false"
         x-transition.opacity.duration.150ms
         class="absolute right-0 mt-2 w-64 origin-top-right rounded-xl border shadow-lg overflow-hidden"
         style="background-color: var(--surface-elevated); border-color: var(--surface-border);">
        <div class="px-4 py-3 border-b" style="border-color: var(--surface-border);">
            <p class="text-sm font-semibold">@username</p>
            <p class="text-xs mt-0.5">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] uppercase tracking-wider font-semibold"
                      style="background-color: var(--accent-soft); color: var(--accent);">@role</span>
            </p>
        </div>

        <ul class="py-1.5 text-sm">
            <li>
                <a href="/account/security" class="flex items-center gap-2 px-4 py-2 hover:opacity-80" style="color: var(--surface-fg);">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
                    Security &amp; sessions
                </a>
            </li>
        </ul>

        <form action="/logout" method="post" class="border-t" style="border-color: var(--surface-border);">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm hover:opacity-80"
                    style="color: var(--surface-fg);">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75"/></svg>
                Sign out
            </button>
        </form>
    </div>
</div>
