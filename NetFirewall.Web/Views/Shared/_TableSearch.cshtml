@model NetFirewall.Web.Models.Shared.TableSearchModel
@*
    Reusable free-text filter for HTMX list tables. Lives in the surrounding
    x-data scope (binds @Model.Var) and triggers the table's `manual-refresh`
    on debounced input. The actual filtering happens server-side; the value is
    carried by the table container's :hx-vals so it persists across polling.
*@
<label class="relative block w-full sm:w-64">
    <span class="absolute inset-y-0 left-0 flex items-center pl-2.5 pointer-events-none text-surface-fg-muted">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.3-4.3m1.8-5.2a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" />
        </svg>
    </span>
    <input type="search"
           class="input pl-8"
           placeholder="@Model.Placeholder"
           autocomplete="off"
           maxlength="@Model.MaxLength"
           aria-label="@Model.Placeholder"
           x-model.trim="@Model.Var"
           @@input.debounce.300ms="htmx.trigger(document.getElementById('@Model.TableId'), 'manual-refresh')" />
</label>
