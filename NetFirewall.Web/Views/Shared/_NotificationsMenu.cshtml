@*
    Notifications popover. Currently rendered with stub data for layout work;
    once the API is in place this should be replaced with an HTMX-driven
    fragment (hx-get="/api/notifications" hx-trigger="load delay:300ms")
    that swaps in the list and the unread badge from a ServiceResponse<T>.
*@
<div class="relative" x-data="{ open: false }">
    <button type="button"
            class="relative h-9 w-9 inline-flex items-center justify-center rounded-md btn-ghost"
            @@click="open = !open"
            aria-label="Notifications">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
        </svg>
        <span class="absolute top-1.5 right-1.5 h-2 w-2 rounded-full bg-accent"></span>
    </button>

    <div x-cloak x-show="open" @@click.outside="open = false"
         x-transition.opacity.duration.150ms
         class="absolute right-0 mt-2 w-80 origin-top-right rounded-xl border shadow-lg overflow-hidden bg-surface-elevated border-surface-border">
        <div class="px-4 py-3 border-b border-surface-border">
            <p class="text-sm font-semibold">Notifications</p>
            <p class="text-xs text-surface-fg-muted">3 unread</p>
        </div>
        <ul class="max-h-80 overflow-auto divide-y border-surface-border">
            <li class="p-4 text-sm">
                <p class="font-medium">DHCP lease pool 80% utilised</p>
                <p class="text-xs mt-1 text-surface-fg-muted">subnet 192.168.10.0/24 · 2 min ago</p>
            </li>
            <li class="p-4 text-sm">
                <p class="font-medium">WAN failover triggered</p>
                <p class="text-xs mt-1 text-surface-fg-muted">primary → secondary · 14 min ago</p>
            </li>
            <li class="p-4 text-sm">
                <p class="font-medium">5 new firewall rules deployed</p>
                <p class="text-xs mt-1 text-surface-fg-muted">42 min ago</p>
            </li>
        </ul>
        <a class="block px-4 py-2.5 text-xs font-medium border-t hover:underline text-accent border-surface-border"
           href="#">View all activity →</a>
    </div>
</div>
