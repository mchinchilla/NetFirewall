@*
    Header notifications popover. The bell badge + list are driven by the real
    system_alerts feed (VPN, WAN failover, …) via /Alerts/menu, loaded on first
    open and refreshed when an alert event fires. "View all activity" links to
    the full history page at /Alerts.
*@
<div class="relative" x-data="{ open: false, loaded: false }">
    <button type="button"
            class="relative h-9 w-9 inline-flex items-center justify-center rounded-md btn-ghost"
            @@click="open = !open; if (open && !loaded) { loaded = true; $nextTick(() => htmx.trigger($refs.notiList, 'loadNotifications')); }"
            aria-label="Notifications">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
        </svg>
        @* Unread dot — shown/hidden by the fragment via a global Alpine store flag. *@
        <span x-show="$store.notifications.unread > 0" x-cloak
              class="absolute top-1.5 right-1.5 h-2 w-2 rounded-full bg-accent"></span>
    </button>

    <div x-cloak x-show="open" @@click.outside="open = false"
         x-transition.opacity.duration.150ms
         class="absolute right-0 mt-2 w-80 origin-top-right rounded-xl border shadow-lg overflow-hidden bg-surface-elevated border-surface-border">
        @* The list fragment is fetched on first open and whenever an alert
           event fires elsewhere in the app. *@
        <div x-ref="notiList"
             hx-get="/Alerts/menu"
             hx-trigger="loadNotifications, refreshNotifications from:body"
             hx-swap="innerHTML">
            @await Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
        </div>
        <a class="block px-4 py-2.5 text-xs font-medium border-t hover:underline text-accent border-surface-border"
           href="/Alerts">View all activity →</a>
    </div>
</div>
