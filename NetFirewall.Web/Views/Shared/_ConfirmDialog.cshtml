@*
    Reusable confirmation dialog — singleton in _Layout. Opened from anywhere
    via Alpine.store('confirm'):

        // promise form (preferred — honors async/await rule #2)
        const ok = await Alpine.store('confirm').ask({
            title: 'Delete lease?',
            message: 'This will release 192.168.10.42 immediately.',
            confirmLabel: 'Delete',
            level: 'danger'
        });
        if (ok) { ... }

        // callback form
        Alpine.store('confirm').show({
            title: 'Apply firewall changes?',
            message: '12 rules will be activated.',
            onConfirm: async () => { await fetch('/firewall/apply', {method: 'POST'}); }
        });

    Levels: 'default' | 'warning' | 'danger' — drive the icon and accent on
    the confirm button. Cancel always closes; Esc and backdrop-click also cancel.
*@
<div x-data
     x-cloak
     x-show="$store.confirm.open"
     @@keydown.escape.window="$store.confirm.cancel()"
     class="fixed inset-0 z-50 flex items-center justify-center p-4"
     role="dialog" aria-modal="true">

    <div class="absolute inset-0"
         style="background-color: rgba(0,0,0,0.45);"
         @@click="$store.confirm.cancel()"></div>

    <div class="relative w-full max-w-md rounded-xl border shadow-xl bg-surface-elevated border-surface-border"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95">

        <div class="flex items-start gap-3 p-5">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full"
                  :style="{
                      'background-color': $store.confirm.level === 'danger'  ? 'var(--feedback-danger-bg)'
                                        : $store.confirm.level === 'warning' ? 'var(--feedback-warning-bg)'
                                        : 'var(--accent-soft)',
                      'color':            $store.confirm.level === 'danger'  ? 'var(--feedback-danger-fg)'
                                        : $store.confirm.level === 'warning' ? 'var(--feedback-warning-fg)'
                                        : 'var(--accent)'
                  }">
                <svg x-show="$store.confirm.level === 'danger'" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
                <svg x-show="$store.confirm.level === 'warning'" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
                <svg x-show="$store.confirm.level === 'default'" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
            </span>
            <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold" x-text="$store.confirm.title"></h3>
                <p class="mt-1 text-sm text-surface-fg-muted" x-text="$store.confirm.message"></p>
            </div>
        </div>

        <div class="flex items-center justify-end gap-2 px-5 pb-4 pt-2 border-t border-surface-border">
            <button type="button" class="btn btn-ghost"
                    @@click="$store.confirm.cancel()"
                    x-text="$store.confirm.cancelLabel"></button>
            <button type="button" class="btn btn-primary"
                    :style="$store.confirm.level === 'danger'
                        ? 'background-color: var(--feedback-danger-btn-bg); color: var(--feedback-danger-btn-fg);'
                        : $store.confirm.level === 'warning'
                            ? 'background-color: var(--feedback-warning-btn-bg); color: var(--feedback-warning-btn-fg);'
                            : ''"
                    @@click="$store.confirm.confirm()"
                    x-text="$store.confirm.confirmLabel"></button>
        </div>
    </div>
</div>
