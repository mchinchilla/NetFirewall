@*
    Top header — composes its right-side widgets from dedicated partials.
    Owns only the search field + sidebar toggles; everything else lives elsewhere.
*@
<header class="sticky top-0 z-30 backdrop-blur-md border-b"
        style="background-color: color-mix(in srgb, var(--surface-elevated) 78%, transparent); border-color: var(--surface-border);">
    <div class="flex h-14 items-center gap-3 px-4 sm:px-6">

        @* Sidebar collapse toggle (desktop) *@
        <button type="button"
                class="hidden md:inline-flex h-9 w-9 items-center justify-center rounded-md btn-ghost"
                @@click="$store.ui.toggleSidebar()"
                aria-label="Toggle sidebar">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
            </svg>
        </button>

        @* Mobile drawer trigger *@
        <button type="button"
                class="md:hidden h-9 w-9 inline-flex items-center justify-center rounded-md btn-ghost"
                @@click="mobileNav = true"
                aria-label="Open navigation">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
            </svg>
        </button>

        @* Search *@
        <div class="hidden md:flex flex-1 max-w-md">
            <label class="relative block w-full">
                <span class="pointer-events-none absolute inset-y-0 left-2.5 flex items-center">
                    <svg class="h-4 w-4" style="color: var(--surface-fg-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.3-4.3M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16Z" />
                    </svg>
                </span>
                <input type="search" class="input pl-8" placeholder="Search leases, rules, IPs…" />
            </label>
        </div>

        <div class="flex-1 md:hidden"></div>

        @await Html.PartialAsync("_NotificationsMenu")
        @await Html.PartialAsync("_ThemeSwitcher")
        @await Html.PartialAsync("_AccountMenu")
    </div>
</header>
