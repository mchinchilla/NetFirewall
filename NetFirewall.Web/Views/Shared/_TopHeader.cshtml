@inject NetFirewall.Services.Settings.IAppSettingsService AppSettings
@*
    Top header — three explicit zones so layout is predictable across breakpoints:
       LEFT   : sidebar toggles (desktop + mobile) + firewall name badge
       CENTER : search box (centered on the available width)
       RIGHT  : notifications, theme switcher, account
    Right cluster uses ml-auto so it always pins flush right regardless of
    whether the search collapses (mobile).
*@
@{
    var firewallName = await AppSettings.GetStringAsync("system.firewall_name");
    if (string.IsNullOrEmpty(firewallName)) firewallName = Environment.MachineName;
}
<header class="sticky top-0 z-30 backdrop-blur-md border-b"
        style="background-color: color-mix(in srgb, var(--surface-elevated) 78%, transparent); border-color: var(--surface-border);">
    <div class="grid h-14 items-center gap-3 px-4 sm:px-6"
         style="grid-template-columns: auto 1fr auto;">

        @* ---------- LEFT ---------- *@
        <div class="flex items-center gap-2">
            <button type="button"
                    class="hidden md:inline-flex h-9 w-9 items-center justify-center rounded-md btn-ghost"
                    @@click="$store.ui.toggleSidebar()"
                    aria-label="Toggle sidebar">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
                </svg>
            </button>
            <button type="button"
                    class="md:hidden h-9 w-9 inline-flex items-center justify-center rounded-md btn-ghost"
                    @@click="mobileNav = true"
                    aria-label="Open navigation">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
                </svg>
            </button>
            <span class="hidden md:inline-flex items-center gap-1.5 px-2 py-1 rounded-md text-xs font-medium"
                  title="@firewallName"
                  style="background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent);">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
                @firewallName
            </span>
        </div>

        @* ---------- CENTER (search) ---------- *@
        <div class="hidden md:flex justify-center"
             x-data="{ open: false }"
             @@click.outside="open = false"
             @@keydown.window.escape="open = false">
            @* NOTE: this is a <div>, not a <label>. The results dropdown holds
               <a> links; a <label> wrapping the input would hijack clicks on
               those links and forward them to the input, so navigation never
               fired. The input keeps an aria-label for accessibility. *@
            <div class="relative block w-full max-w-xl">
                <span class="pointer-events-none absolute inset-y-0 left-2.5 flex items-center z-10">
                    <svg class="h-4 w-4 text-surface-fg-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.3-4.3M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16Z" />
                    </svg>
                </span>
                <input type="search"
                       name="q"
                       class="input pl-8"
                       placeholder="Search rules, objects, peers…"
                       aria-label="Search rules, objects, peers"
                       autocomplete="off"
                       hx-get="/Search/dropdown"
                       hx-trigger="input changed delay:200ms, focus"
                       hx-target="#search-dropdown"
                       hx-swap="innerHTML"
                       @@focus="open = true"
                       @@input="open = true" />

                <div id="search-dropdown"
                     x-show="open" x-cloak
                     x-transition.opacity.duration.100ms
                     class="absolute left-0 right-0 top-full mt-1 z-30 rounded-md border shadow-lg overflow-hidden bg-surface-elevated border-surface-border"></div>
            </div>
        </div>
        @* mobile placeholder so the right column still pins right *@
        <div class="md:hidden"></div>

        @* ---------- RIGHT ---------- *@
        <div class="flex items-center gap-1.5 justify-end">
            @await Html.PartialAsync("_NotificationsMenu")
            @await Html.PartialAsync("_ThemeSwitcher")
            @await Html.PartialAsync("_AccountMenu")
        </div>
    </div>
</header>
