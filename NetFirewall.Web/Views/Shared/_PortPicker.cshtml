@model NetFirewall.Web.Models.AddressPickerViewModel
@*
    Tag-input with autocomplete for firewall rule destination_ports fields.
    Sister of _AddressPicker — same UX but pulls from /Network/Services
    and treats numeric ports / "start-end" ranges as literals.
*@
@{
    var fieldId = $"port-{Model.Name.Replace(".", "-")}";
}

<div class="space-y-1.5"
     x-data="portPicker(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Value ?? string.Empty)))"
     x-init="$nextTick(() => $refs.hidden.value = csv)">
    <label for="@fieldId" class="block text-xs font-medium" style="color: var(--surface-fg);">
        @Model.Label
        @if (Model.Required)
        {
            <span style="color: var(--feedback-danger-fg);">*</span>
        }
    </label>

    <input type="hidden" name="@Model.Name" :value="csv" x-ref="hidden" />

    <div class="relative">
        <div class="input flex flex-wrap items-center gap-1.5 min-h-9 cursor-text"
             style="padding: 0.375rem 0.5rem;"
             @@click="$refs.text.focus()">
            <template x-for="(tag, i) in tags" :key="`${tag}-${i}`">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium"
                      :style="looksLikeLiteral(tag)
                          ? 'background: color-mix(in srgb, var(--surface-fg-muted) 14%, transparent); color: var(--surface-fg);'
                          : 'background: color-mix(in srgb, var(--feedback-info-fg) 14%, transparent); color: var(--feedback-info-fg);'">
                    <svg x-show="!looksLikeLiteral(tag)" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z"/></svg>
                    <span class="font-mono" x-text="tag"></span>
                    <button type="button" class="-mr-0.5 opacity-60 hover:opacity-100"
                            @@click.stop="removeTag(i)" tabindex="-1"
                            aria-label="Remove">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                    </button>
                </span>
            </template>
            <input type="text" id="@fieldId" x-ref="text"
                   x-model="input"
                   @@input="search()"
                   @@keydown="onKey($event)"
                   @@blur="setTimeout(() => open = false, 150)"
                   @@focus="if (suggestions.length > 0) open = true"
                   class="flex-1 min-w-32 outline-none bg-transparent text-sm"
                   placeholder="@(Model.Placeholder ?? "Type port or service name…")" />
        </div>

        <div x-show="open && suggestions.length > 0" x-cloak
             x-transition.opacity.duration.100ms
             class="absolute z-20 left-0 right-0 mt-1 max-h-60 overflow-y-auto rounded-md shadow-lg border"
             style="background: var(--surface-elevated); border-color: var(--surface-border);">
            <template x-for="(s, i) in suggestions" :key="s.id">
                <button type="button"
                        @@mousedown.prevent="addTag(s.name)"
                        @@mouseenter="active = i"
                        class="w-full text-left px-3 py-2 text-sm flex items-baseline justify-between gap-3"
                        :style="i === active
                            ? 'background: color-mix(in srgb, var(--feedback-info-fg) 12%, transparent);'
                            : ''">
                    <span class="font-mono font-medium" x-text="s.name"></span>
                    <span class="text-xs" style="color: var(--surface-fg-muted);">
                        <span x-text="s.protocol"></span>
                        <span x-show="s.port"> · <span x-text="s.port" class="font-mono"></span></span>
                        <span x-show="s.category"> · <span x-text="s.category"></span></span>
                    </span>
                </button>
            </template>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Help))
    {
        <p class="text-xs" style="color: var(--surface-fg-muted);">@Model.Help</p>
    }
</div>
