@*
    Sidebar nav items. Reused by desktop rail and mobile drawer.
    When ViewData["ForceExpanded"] == true, labels render unconditionally
    (mobile drawer never collapses).
*@
@{
    var forceExpanded = ViewData["ForceExpanded"] as bool? ?? false;
    string ShowLabel() => forceExpanded ? string.Empty : "x-show=\"!$store.ui.sidebarCollapsed\" x-transition.opacity";

    var path = Context.Request.Path.Value ?? "/";

    // True when the current request is exactly this URL or a child route.
    // Use trailing-slash matching so "/Firewall/Qos" doesn't light up
    // "/Firewall/QosOther" but does match "/Firewall/Qos/{id}/Classes".
    bool IsActive(string href)
    {
        if (string.IsNullOrEmpty(href) || href == "#") return false;
        if (href == "/") return path == "/";
        return string.Equals(path, href, StringComparison.OrdinalIgnoreCase)
               || path.StartsWith(href + "/", StringComparison.OrdinalIgnoreCase);
    }

    // True when ANY child route in the same section matches — used to auto-open
    // the collapsible group on first render.
    bool AnyActive(params string[] hrefs) => hrefs.Any(IsActive);

    string ActiveCls(string href) => IsActive(href) ? " active" : string.Empty;

    // Pre-compute group open states — avoids re-evaluating per link.
    var dhcpHrefs = new[] {
        Url.Action("Index", "DhcpSubnets")!, Url.Action("Index", "DhcpReservations")!,
        Url.Action("Index", "DhcpLeases")!, Url.Action("Index", "DhcpClasses")!,
        Url.Action("Index", "DhcpDdns")!, Url.Action("Index", "DhcpFailover")!
    };
    var fwHrefs = new[] {
        Url.Action("Index", "FwFilterRules")!,
        Url.Action("Index", "FwNatRules")!, Url.Action("Index", "FwPortForwards")!,
        Url.Action("Index", "FwTrafficMarks")!, Url.Action("Index", "FwMangleRules")!,
        Url.Action("Index", "FwQosConfigs")!, Url.Action("Index", "FwSchedules")!,
        Url.Action("Index", "FwAuditLog")!, Url.Action("Index", "FwApply")!
    };
    var netHrefs = new[] {
        Url.Action("Interfaces", "Network")!, Url.Action("Index", "StaticRoutes")!,
        Url.Action("Index", "NetworkObjects")!, Url.Action("Index", "NetworkServices")!,
        Url.Action("Index", "WanFailover")!
    };

    var dhcpOpen = AnyActive(dhcpHrefs) ? "true" : "false";
    var fwOpen   = AnyActive(fwHrefs)   ? "true" : "false";
    var netOpen  = AnyActive(netHrefs)  ? "true" : "false";
}

<a href="@Url.Action("Index", "Home")" class="nav-link@(ActiveCls(Url.Action("Index", "Home")!))">
    <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955a1.5 1.5 0 0 1 2.121 0L21 11.999M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
    </svg>
    <span class="whitespace-nowrap" @Html.Raw(ShowLabel())>Dashboard</span>
</a>

@* DHCP section *@
