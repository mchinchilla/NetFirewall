    <button type="button" class="w-full nav-link" @@click="open = !open">
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3V6.75a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v4.5a3 3 0 0 1-3 3m-13.5 0a3 3 0 0 0-3 3v3a3 3 0 0 0 3 3h13.5a3 3 0 0 0 3-3v-3a3 3 0 0 0-3-3m-9.75 4.5h.008v.008H8.25v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375-9h.008v.008H8.25V9.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
        </svg>
        <span class="flex-1 text-left whitespace-nowrap" @Html.Raw(ShowLabel())>DHCP</span>
        <svg class="h-4 w-4 transition-transform shrink-0" :class="open && 'rotate-90'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" @Html.Raw(ShowLabel())>
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
    </button>
    <div x-show="open" x-transition.duration.150ms class="ml-9 mt-1 space-y-0.5" @Html.Raw(ShowLabel())>
        <a href="@Url.Action("Index", "DhcpSubnets")"      class="nav-link py-1.5@(ActiveCls(Url.Action("Index", "DhcpSubnets")!))">Subnets &amp; pools</a>
        <a href="@Url.Action("Index", "DhcpReservations")" class="nav-link py-1.5@(ActiveCls(Url.Action("Index", "DhcpReservations")!))">Reservations</a>
        <a href="@Url.Action("Index", "DhcpLeases")"       class="nav-link py-1.5@(ActiveCls(Url.Action("Index", "DhcpLeases")!))">Leases (live)</a>
        <a href="@Url.Action("Index", "DhcpClasses")"      class="nav-link py-1.5@(ActiveCls(Url.Action("Index", "DhcpClasses")!))">Classes</a>
        <a href="@Url.Action("Index", "DhcpDdns")"         class="nav-link py-1.5@(ActiveCls(Url.Action("Index", "DhcpDdns")!))">Dynamic DNS</a>
        <a href="@Url.Action("Index", "DhcpFailover")"     class="nav-link py-1.5@(ActiveCls(Url.Action("Index", "DhcpFailover")!))">Failover</a>
    </div>
</div>

