<!DOCTYPE html>
@inject NetFirewall.Services.Settings.IAppSettingsService AppSettings
@*
    Dashboard shell — composes partials only. Each visual concern lives in
    its own _Partial under Views/Shared/ per project rule #7.

    data-theme/data-mode reflect the configured appearance.* defaults; the
    pre-paint hydrator in site.js overrides them with the user's localStorage
    preference when present.
*@
@{
    var defaultTheme = await AppSettings.GetStringAsync("appearance.default_theme");
    var defaultMode  = await AppSettings.GetStringAsync("appearance.default_mode");
    if (string.IsNullOrEmpty(defaultTheme)) defaultTheme = "boulder";
    if (string.IsNullOrEmpty(defaultMode))  defaultMode  = "light";
}
<html lang="en" class="h-full" data-theme="@defaultTheme" data-mode="@defaultMode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NetFirewall</title>
    @await Html.PartialAsync("_HeadStyles")
    @* Optional per-page <head> assets (e.g. a vendored stylesheet like xterm.css).
       For authored styles use Tailwind utilities / tokens in site.css — never a
       per-page CSS file (rule #3). *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="flex flex-col min-h-screen relative overflow-x-hidden"
      x-data="{ mobileNav: false }">

    @await Html.PartialAsync("_BackgroundBlobs")

    <div class="flex flex-1 min-h-0">
        @await Html.PartialAsync("_Sidebar")

        <div class="flex flex-col flex-1 min-w-0">
            @await Html.PartialAsync("_TopHeader")
            @await Html.PartialAsync("_DaemonModeBanner")
            @* Active-system-alerts banner (VPN/WAN down, etc). Self-populating +
               self-clearing: polls /Alerts/banner every 10s and swaps in
               _AlertsBanner — empty markup when nothing is active. Each poll also
               emits `alertsState` (HX-Trigger) which drives the bell badge + the
               audible cue app-wide. Also refreshes on WireGuard events. When the
               Monitoring page sets $store.alerts.paused, the htmx:beforeRequest
               hook in site.js cancels these polls so the banner/badge/sound freeze
               with that page's live metrics. *@
            <div id="alerts-banner"
                 hx-get="/Alerts/banner"
                 hx-trigger="load, every 10s, refreshWireGuard from:body"
                 hx-swap="innerHTML"></div>
            @await Html.PartialAsync("_Breadcrumb")

            <main role="main" class="flex-1 px-4 sm:px-6 lg:px-8 py-6"
                  style="animation: var(--animate-fade-in);">
                @RenderBody()
            </main>

            @await Html.PartialAsync("_Footer")
        </div>
    </div>

    @await Html.PartialAsync("_Toasts")
    @await Html.PartialAsync("_ConfirmDialog")
    @await Html.PartialAsync("_Drawer")
    @await Html.PartialAsync("_ElevationModal")

    @await Html.PartialAsync("_Scripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
