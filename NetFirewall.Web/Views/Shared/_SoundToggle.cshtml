@*
    Audible-alert mute toggle. Bound to the persisted UI store (soundAlerts).
    On by default; the click is also the user gesture that unlocks Web Audio.
    Two icons swap on state so it's obvious at a glance whether alerts are audible.
*@
<button type="button"
        class="h-9 w-9 inline-flex items-center justify-center rounded-md btn-ghost"
        @@click="$store.ui.toggleSoundAlerts()"
        :aria-label="$store.ui.soundAlerts ? 'Mute alert sounds' : 'Unmute alert sounds'"
        :title="$store.ui.soundAlerts ? 'Alert sounds on' : 'Alert sounds off'">
    @* Speaker with waves — sounds ON *@
    <svg x-show="$store.ui.soundAlerts" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
    </svg>
    @* Speaker muted — sounds OFF *@
    <svg x-show="!$store.ui.soundAlerts" x-cloak class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
    </svg>
</button>
