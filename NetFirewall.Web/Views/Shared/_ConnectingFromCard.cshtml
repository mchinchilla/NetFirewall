@model NetFirewall.Web.Models.Auth.ConnectionInfoViewModel
@{
    // Live ticker for the uptime line — reuses the runtimeMetrics Alpine component
    // (defined in site.js) the login card already uses, seeded with the process
    // boot epoch so it counts up without a server roundtrip.
    var startedMs = Model.StartedAt.ToUnixTimeMilliseconds();
}

<div class="px-4 py-3 border-t border-surface-border" x-data="runtimeMetrics(@startedMs)">
    <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] uppercase tracking-wider font-semibold text-surface-fg-muted">Connecting from</p>
        <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-feedback-success-fg">
            <span class="relative flex h-1.5 w-1.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-60 bg-feedback-success-bd"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-feedback-success-bd"></span>
            </span>
            LIVE
        </span>
    </div>

    <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-xs text-surface-fg-muted">
        @* Real client IP (the LAN IP for an on-site admin). *@
        <div class="flex items-center gap-1.5" title="Client IP">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z"/></svg>
            <dt class="sr-only">Client IP</dt>
            <dd class="font-mono text-surface-fg truncate" title="@Model.ClientIp">@Model.ClientIp</dd>
        </div>

        @* Uptime (live). *@
        <div class="flex items-center gap-1.5" title="Uptime">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5 9 9.75l3.75 3.75 6-6m0 0H15.75m3-0v3"/></svg>
            <dt class="sr-only">Uptime</dt>
            <dd class="font-mono text-surface-fg" x-text="uptime"></dd>
        </div>

        @* Geo / ASN / TZ — same fragment the login card uses (egress for LAN clients). *@
        @await Html.PartialAsync("_GeoInfoFragment", Model.Geo)
    </dl>

    @if (Model.Geo.ForSelf && Model.Geo.Ok)
    {
        <p class="text-[10px] mt-2 text-surface-fg-muted">Location reflects the firewall's WAN uplink, not your LAN address.</p>
    }
</div>
