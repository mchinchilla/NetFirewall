@*
    Footer — minimal status bar.
*@
<footer class="border-t mt-auto"
        style="border-color: var(--surface-border); background-color: color-mix(in srgb, var(--surface-elevated) 60%, transparent);">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2 px-6 py-3 text-xs"
         style="color: var(--surface-fg-muted);">
        <div class="flex items-center gap-3">
            <span>&copy; @DateTime.UtcNow.Year NetFirewall</span>
            <span class="hidden sm:inline">·</span>
            <span class="hidden sm:inline">v0.1.0-dev</span>
        </div>
        <div class="flex items-center gap-3">
            <a href="#" class="hover:underline">Documentation</a>
            <a href="#" class="hover:underline">API</a>
            <a href="#" class="hover:underline">GitHub</a>
        </div>
    </div>
</footer>
