@model NetFirewall.Web.Models.Setup.Step3ViewModel
@using NetFirewall.Web.Models

<header class="mb-5">
    <h2 class="text-lg font-semibold">Step 3 — Firewall basics</h2>
    <p class="text-sm mt-1 text-surface-fg-muted">
        Pick the baseline policy. Each toggle adds a few nftables rules — you can edit individual rules afterwards from <span class="font-medium text-surface-fg">Firewall → Rules</span>.
    </p>
</header>

@* Sibling Back form — see step 2 for rationale. *@
<form id="wizard-back-3" method="post" action="/setup/wizard/back/3" class="hidden">
    @Html.AntiForgeryToken()
</form>

<form id="wizard-step-3" method="post" action="/setup/wizard/step/3">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.EnableNat), Label = "Enable NAT (masquerade LAN→WAN)", Kind = FormFieldKind.Checkbox,
            Value = Model.EnableNat ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.ForwardLanToWan), Label = "Allow LAN → WAN forwarding", Kind = FormFieldKind.Checkbox,
            Value = Model.ForwardLanToWan ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.AllowSsh), Label = "Allow SSH from any LAN (port 22)", Kind = FormFieldKind.Checkbox,
            Value = Model.AllowSsh ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.AllowIcmp), Label = "Allow ICMP (ping)", Kind = FormFieldKind.Checkbox,
            Value = Model.AllowIcmp ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.AllowDhcp), Label = "Allow DHCP server traffic on LAN", Kind = FormFieldKind.Checkbox,
            Value = Model.AllowDhcp ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.AllowDns), Label = "Allow DNS queries from LAN", Kind = FormFieldKind.Checkbox,
            Value = Model.AllowDns ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.AllowWebInterface), Label = "Allow access to this web admin from LAN", Kind = FormFieldKind.Checkbox,
            Value = Model.AllowWebInterface ? "true" : "false"
        })
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.BlockInvalidPackets), Label = "Drop invalid / malformed packets", Kind = FormFieldKind.Checkbox,
            Value = Model.BlockInvalidPackets ? "true" : "false"
        })
    </div>

    <div class="mt-5 max-w-xs">
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.WebInterfacePort), Label = "Web admin port", Kind = FormFieldKind.Number, Required = true,
            Value = Model.WebInterfacePort.ToString(), Min = "1", Max = "65535"
        })
    </div>

    <div class="mt-6 pt-4 border-t flex items-center justify-between gap-2 border-surface-border">
        <button type="submit" form="wizard-back-3" class="btn btn-ghost">← Back</button>
        <button type="submit" class="btn btn-primary">
            Continue
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </button>
    </div>
</form>
