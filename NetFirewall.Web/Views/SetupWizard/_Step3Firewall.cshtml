@model NetFirewall.Web.Models.Setup.Step3ViewModel
@using NetFirewall.Web.Models

@*
    Step 3 — firewall baseline. Toggles are grouped by intent: what we accept
    *into* the firewall (input chain), what we *forward* through it (forward
    chain), and basic *hardening*. A small preview pane below summarizes which
    rules each toggle will create so the operator knows what they're enabling.

    Per-LAN service overrides are intentionally NOT in this step — once setup
    completes, Firewall → Rules has full per-interface tuning. The wizard is
    for picking a reasonable baseline, not for fine-grained policy.
*@

<header class="mb-5">
    <h2 class="text-lg font-semibold">Step 3 — Firewall baseline</h2>
    <p class="text-sm mt-1 text-surface-fg-muted">
        Pick which traffic the firewall accepts. These choices generate the initial nftables ruleset — you can refine per-rule later in
        <span class="font-medium text-surface-fg">Firewall → Rules</span>.
    </p>
</header>

<form id="wizard-back-3" method="post" action="/setup/wizard/back/3" class="hidden">
    @Html.AntiForgeryToken()
</form>

<form id="wizard-step-3" method="post" action="/setup/wizard/step/3"
      x-data="{
          ssh:        @(Model.AllowSsh ? "true" : "false"),
          icmp:       @(Model.AllowIcmp ? "true" : "false"),
          dhcp:       @(Model.AllowDhcp ? "true" : "false"),
          dns:        @(Model.AllowDns ? "true" : "false"),
          webui:      @(Model.AllowWebInterface ? "true" : "false"),
          webPort:   '@Model.WebInterfacePort',
          nat:        @(Model.EnableNat ? "true" : "false"),
          forward:    @(Model.ForwardLanToWan ? "true" : "false"),
          dropInvalid:@(Model.BlockInvalidPackets ? "true" : "false"),
          preview:    false
      }">
    @Html.AntiForgeryToken()

    <!-- ── Inbound services ── -->
    <section class="rounded-lg border p-4 border-surface-border" style="background-color: var(--surface-elevated);">
        <header class="mb-3">
            <h3 class="text-sm font-semibold">Inbound services</h3>
            <p class="text-xs text-surface-fg-muted mt-0.5">What the firewall itself accepts from LAN clients.</p>
        </header>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.AllowSsh), Label = "SSH (port 22)", Kind = FormFieldKind.Checkbox,
                Value = Model.AllowSsh ? "true" : "false", AlpineModel = "ssh"
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.AllowIcmp), Label = "ICMP (ping)", Kind = FormFieldKind.Checkbox,
                Value = Model.AllowIcmp ? "true" : "false", AlpineModel = "icmp"
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.AllowDhcp), Label = "DHCP server on LAN (udp/67-68)", Kind = FormFieldKind.Checkbox,
                Value = Model.AllowDhcp ? "true" : "false", AlpineModel = "dhcp"
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.AllowDns), Label = "DNS queries from LAN (udp/53)", Kind = FormFieldKind.Checkbox,
                Value = Model.AllowDns ? "true" : "false", AlpineModel = "dns"
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.AllowWebInterface), Label = "This web admin from LAN", Kind = FormFieldKind.Checkbox,
                Value = Model.AllowWebInterface ? "true" : "false", AlpineModel = "webui"
            })
            <div x-show="webui" x-cloak class="max-w-[12rem]">
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.WebInterfacePort), Label = "Web admin port", Kind = FormFieldKind.Number, Required = true,
                    Value = Model.WebInterfacePort.ToString(), Min = "1", Max = "65535", AlpineModel = "webPort"
                })
            </div>
        </div>
    </section>

    <!-- ── Forwarding (LAN → WAN) ── -->
    <section class="rounded-lg border p-4 mt-4 border-surface-border" style="background-color: var(--surface-elevated);">
        <header class="mb-3">
            <h3 class="text-sm font-semibold">Forwarding</h3>
            <p class="text-xs text-surface-fg-muted mt-0.5">How traffic flows between LAN and WAN.</p>
        </header>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.ForwardLanToWan), Label = "Allow LAN → WAN forwarding", Kind = FormFieldKind.Checkbox,
                Value = Model.ForwardLanToWan ? "true" : "false", AlpineModel = "forward",
                Help = "Without this, LAN clients have no internet."
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.EnableNat), Label = "Masquerade LAN behind WAN IP (NAT)", Kind = FormFieldKind.Checkbox,
                Value = Model.EnableNat ? "true" : "false", AlpineModel = "nat",
                Help = "Required for private LANs (RFC1918) to reach the internet."
            })
        </div>
        <div x-show="forward && !nat" x-cloak
             class="mt-3 rounded-md border-l-2 px-3 py-2 text-xs flex items-start gap-2 bg-feedback-warning-bg text-feedback-warning-fg border-feedback-warning-bd">
            <svg class="h-4 w-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126Z"/></svg>
            <span>Forwarding without NAT is unusual. Only enable both off if your LAN uses public IPs or another box is doing the masquerade.</span>
        </div>
    </section>

    <!-- ── Hardening ── -->
    <section class="rounded-lg border p-4 mt-4 border-surface-border" style="background-color: var(--surface-elevated);">
        <header class="mb-3">
            <h3 class="text-sm font-semibold">Hardening</h3>
            <p class="text-xs text-surface-fg-muted mt-0.5">Sensible defaults that block obvious attack patterns.</p>
        </header>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.BlockInvalidPackets), Label = "Drop invalid / malformed packets", Kind = FormFieldKind.Checkbox,
                Value = Model.BlockInvalidPackets ? "true" : "false", AlpineModel = "dropInvalid",
                Help = "Drops packets the kernel's conntrack can't classify — they're nearly always scans."
            })
        </div>
    </section>

    <!-- ── Preview of generated rules ── -->
    <section class="mt-4 rounded-lg border border-surface-border">
        <button type="button" class="w-full px-4 py-3 flex items-center justify-between text-left hover:opacity-90"
                @@click="preview = !preview">
            <span class="text-sm font-medium">Preview rules that will be created</span>
            <svg class="h-4 w-4 transition" :class="{ 'rotate-180': preview }" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
        </button>
        <div x-show="preview" x-cloak class="border-t px-4 py-3 border-surface-border" style="background-color: var(--surface-muted);">
            <ul class="space-y-1 text-xs font-mono">
                <li class="text-surface-fg-muted">Always: accept established/related; accept loopback; default-drop on input</li>
                <li x-show="icmp">Allow ICMP echo from any source</li>
                <li x-show="ssh">Allow tcp/22 from any LAN (NEW connections)</li>
                <li x-show="dhcp">Allow udp/67-68 on each LAN iface</li>
                <li x-show="dns">Allow udp/53 from each LAN iface</li>
                <li x-show="webui"><span>Allow tcp/<span x-text="webPort"></span> from each LAN iface (NEW)</span></li>
                <li x-show="forward">Forward: accept LAN → WAN NEW; accept established/related back</li>
                <li x-show="nat">NAT masquerade: src=LAN cidr → out=WAN iface</li>
                <li x-show="dropInvalid">Drop packets with ctstate INVALID</li>
            </ul>
            <p class="mt-2 text-[11px] text-surface-fg-muted italic">
                Final nftables.conf is rendered on Apply. You can review and tune in Firewall → Rules after the wizard completes.
            </p>
        </div>
    </section>

    <div class="mt-6 pt-4 border-t flex items-center justify-between gap-2 border-surface-border">
        <button type="submit" form="wizard-back-3" class="btn btn-ghost">← Back</button>
        <button type="submit" class="btn btn-primary">
            Continue
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </button>
    </div>
</form>
