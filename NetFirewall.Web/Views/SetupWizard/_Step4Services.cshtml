@model NetFirewall.Web.Models.Setup.Step4ViewModel
@using NetFirewall.Web.Models

<header class="mb-5">
    <h2 class="text-lg font-semibold">Step 4 — Optional services</h2>
    <p class="text-sm mt-1" style="color: var(--surface-fg-muted);">
        All optional. Skip anything you'll set up later — every section can be toggled from its dedicated page after the wizard completes.
    </p>
</header>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
{
    <div class="mb-5 rounded-md border-l-2 px-3 py-2 text-sm"
         style="background-color: var(--feedback-danger-bg); color: var(--feedback-danger-fg); border-color: var(--feedback-danger-bd);">
        @foreach (var err in ViewData.ModelState[""]!.Errors) { <p>@err.ErrorMessage</p> }
    </div>
}

@* Sibling Back form — see step 2 for rationale. *@
<form id="wizard-back-4" method="post" action="/setup/wizard/back/4" class="hidden">
    @Html.AntiForgeryToken()
</form>

<form id="wizard-step-4" method="post" action="/setup/wizard/step/4"
      x-data="{ dns: @(Model.EnableDnsForwarder ? "true" : "false"),
                wg:  @(Model.EnableWireGuard   ? "true" : "false"),
                qos: @(Model.EnableQos          ? "true" : "false") }">
    @Html.AntiForgeryToken()

    <div class="space-y-5">

        @* ----- DNS forwarder ----- *@
        <div class="rounded-lg border p-4" style="border-color: var(--surface-border);">
            <label class="flex items-start gap-2.5 cursor-pointer">
                <input type="checkbox" name="EnableDnsForwarder" value="true" x-model="dns" class="mt-0.5 h-4 w-4 rounded" />
                <div>
                    <p class="text-sm font-medium">DNS forwarder</p>
                    <p class="text-xs mt-0.5" style="color: var(--surface-fg-muted);">Resolve LAN queries via configured upstreams.</p>
                </div>
            </label>

            <div x-show="dns" x-cloak x-transition class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.UpstreamDns1), Label = "Upstream DNS 1", Value = Model.UpstreamDns1, Placeholder = "8.8.8.8",
                    AlpineExtra = ":required=\"dns\""
                })
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.UpstreamDns2), Label = "Upstream DNS 2", Value = Model.UpstreamDns2, Placeholder = "1.1.1.1"
                })
            </div>
        </div>

        @* ----- WireGuard ----- *@
        <div class="rounded-lg border p-4" style="border-color: var(--surface-border);">
            <label class="flex items-start gap-2.5 cursor-pointer">
                <input type="checkbox" name="EnableWireGuard" value="true" x-model="wg" class="mt-0.5 h-4 w-4 rounded" />
                <div>
                    <p class="text-sm font-medium">WireGuard VPN</p>
                    <p class="text-xs mt-0.5" style="color: var(--surface-fg-muted);">Set up a wg0 interface — keys generated next.</p>
                </div>
            </label>

            <div x-show="wg" x-cloak x-transition class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.WireGuardSubnet), Label = "WireGuard subnet (CIDR)", Value = Model.WireGuardSubnet,
                    Placeholder = "10.100.0.0/24",
                    Pattern = @"^(\d{1,3}\.){3}\d{1,3}/\d{1,2}$"
                })
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.WireGuardPort), Label = "Listen port (UDP)", Kind = FormFieldKind.Number,
                    Value = Model.WireGuardPort.ToString(), Min = "1", Max = "65535"
                })
            </div>
        </div>

        @* ----- QoS ----- *@
        <div class="rounded-lg border p-4" style="border-color: var(--surface-border);">
            <label class="flex items-start gap-2.5 cursor-pointer">
                <input type="checkbox" name="EnableQos" value="true" x-model="qos" class="mt-0.5 h-4 w-4 rounded" />
                <div>
                    <p class="text-sm font-medium">QoS / bandwidth shaping</p>
                    <p class="text-xs mt-0.5" style="color: var(--surface-fg-muted);">Cap total throughput per direction (HTB).</p>
                </div>
            </label>

            <div x-show="qos" x-cloak x-transition class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.DownloadBandwidthMbps), Label = "Download (Mbps)", Kind = FormFieldKind.Number,
                    Value = Model.DownloadBandwidthMbps?.ToString(), Min = "1", Max = "100000",
                    AlpineExtra = ":required=\"qos\""
                })
                @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                    Name = nameof(Model.UploadBandwidthMbps), Label = "Upload (Mbps)", Kind = FormFieldKind.Number,
                    Value = Model.UploadBandwidthMbps?.ToString(), Min = "1", Max = "100000",
                    AlpineExtra = ":required=\"qos\""
                })
            </div>
        </div>
    </div>

    <div class="mt-6 pt-4 border-t flex items-center justify-between gap-2"
         style="border-color: var(--surface-border);">
        <button type="submit" form="wizard-back-4" class="btn btn-ghost">← Back</button>
        <button type="submit" class="btn btn-primary">
            Continue to review
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </button>
    </div>
</form>
