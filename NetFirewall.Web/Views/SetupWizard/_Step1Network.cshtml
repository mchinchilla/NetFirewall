@model NetFirewall.Web.Models.Setup.Step1ViewModel

<header class="mb-5">
    <h2 class="text-lg font-semibold">Step 1 — Network interfaces</h2>
    <p class="text-sm mt-1 text-surface-fg-muted">
        Assign each detected NIC a role. Disabled interfaces won't be touched by NetFirewall.
        WAN secondary lets the WAN Monitor fail over automatically.
    </p>
</header>

<form method="post" action="/setup/wizard/step/1" x-data="{}">
    @Html.AntiForgeryToken()

    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-surface-fg-muted">
                    <th class="px-5 py-2 font-medium">Interface</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">MAC</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Current IP</th>
                    <th class="px-5 py-2 font-medium">Suggested</th>
                    <th class="px-5 py-2 font-medium">Role</th>
                </tr>
            </thead>
            <tbody class="divide-y border-surface-border">
                @for (var i = 0; i < Model.Interfaces.Count; i++)
                {
                    var row = Model.Interfaces[i];
                    <tr>
                        <td class="px-5 py-3 align-top">
                            <input type="hidden" name="Interfaces[@i].Name" value="@row.Name" />
                            <div class="flex items-center gap-2">
                                <span class="inline-block h-2 w-2 rounded-full"
                                      style="background-color: @(row.IsUp ? "var(--feedback-success-bd)" : "var(--surface-fg-muted)");"></span>
                                <span class="font-medium font-mono text-xs">@row.Name</span>
                            </div>
                        </td>
                        <td class="px-5 py-3 align-top hidden md:table-cell font-mono text-xs text-surface-fg-muted">@(row.MacAddress ?? "—")</td>
                        <td class="px-5 py-3 align-top hidden lg:table-cell font-mono text-xs text-surface-fg-muted">@(row.CurrentIp ?? "—")</td>
                        <td class="px-5 py-3 align-top">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium bg-accent-soft text-accent">@(row.SuggestedRole ?? "—")</span>
                        </td>
                        <td class="px-5 py-3 align-top w-44">
                            <select name="Interfaces[@i].Role" class="input py-1.5 text-sm">
                                <option value="disabled"      selected="@(row.Role == "disabled")">Disabled</option>
                                <option value="wan_primary"   selected="@(row.Role == "wan_primary")">WAN primary</option>
                                <option value="wan_secondary" selected="@(row.Role == "wan_secondary")">WAN secondary</option>
                                <option value="lan"           selected="@(row.Role == "lan")">LAN</option>
                                <option value="vpn"           selected="@(row.Role == "vpn")">VPN</option>
                            </select>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Interfaces.Count == 0)
    {
        <div class="text-sm py-10 text-center text-surface-fg-muted">
            No network interfaces detected. Plug in a NIC and reload.
        </div>
    }

    <div class="mt-6 pt-4 border-t flex items-center justify-end gap-2 border-surface-border">
        <a href="/" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary">
            Continue
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </button>
    </div>
</form>
