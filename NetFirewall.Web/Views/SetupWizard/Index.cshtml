@model NetFirewall.Web.Models.Setup.WizardPageViewModel
@{
    ViewData["Title"] = "Setup wizard";
    var isRerun = ViewBag.IsRerun as bool? ?? false;
    // "Resuming" = user has saved at least step 1 (CurrentStep > 1) and isn't doing a forced re-run.
    var isResuming = !isRerun && !Model.IsCompleted && Model.MaxUnlockedStep > 1;
}

<div class="mb-6" style="animation: var(--animate-slide-up);">
    @* ASCII logo — decorative, matches the appliance console/MOTD branding. *@
    <pre aria-hidden="true" class="hidden sm:block font-mono text-accent text-[10px] leading-tight select-none mb-3">
 _   _      _   _____ _                        _ _
| \ | | ___| |_|  ___(_)_ __ _____      ____ _| | |
|  \| |/ _ \ __| |_  | | '__/ _ \ \ /\ / / _` | | |
| |\  |  __/ |_|  _| | | | |  __/\ V  V / (_| | | |
|_| \_|\___|\__|_|   |_|_|  \___| \_/\_/ \__,_|_|_|</pre>
    <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">
        @(isRerun ? "Re-running setup" : (isResuming ? "Resuming setup" : "First-run setup"))
    </p>
    <h1 class="text-2xl font-semibold tracking-tight">NetFirewall setup wizard</h1>
    <p class="text-sm mt-1 text-surface-fg-muted">
        Five guided steps. Your progress saves after each step — close the tab and resume later.
    </p>
</div>

@if (isResuming)
{
    <div class="mb-6 rounded-md border-l-2 px-3 py-2 text-sm flex items-start gap-3 bg-feedback-info-bg text-feedback-info-fg border-feedback-info-bd"
         role="status">
        <svg class="h-5 w-5 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        <div>
            <p class="font-semibold">Welcome back — picking up at step @Model.CurrentStep.</p>
            <p class="text-xs mt-0.5">
                Earlier steps are saved and reachable from the stepper above. Nothing is applied to the live system until you reach step 5 and click <span class="font-medium">Apply setup</span>.
            </p>
        </div>
    </div>
}

@if (isRerun)
{
    <div class="mb-6 rounded-md border-l-2 px-3 py-3 text-sm flex items-start gap-3 bg-feedback-warning-bg text-feedback-warning-fg border-feedback-warning-bd"
         role="status">
        <svg class="h-5 w-5 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
        <div>
            <p class="font-semibold">You're re-running a completed wizard.</p>
            <p class="text-xs mt-0.5">
                Your saved configuration is loaded. Saving each step overwrites it; nothing is applied to the live system until you click <span class="font-medium">Apply setup</span> in step 5.
            </p>
        </div>
    </div>
}

@await Html.PartialAsync("_Stepper", Model)

<section class="card max-w-4xl" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
    @switch (Model.CurrentStep)
    {
        case 1: @await Html.PartialAsync("_Step1Network", Model.Step1); break;
        case 2: @await Html.PartialAsync("_Step2Lan", Model.Step2); break;
        case 3: @await Html.PartialAsync("_Step3Firewall", Model.Step3); break;
        case 4: @await Html.PartialAsync("_Step4Services", Model.Step4); break;
        case 5: @await Html.PartialAsync("_Step5Review", Model); break;
    }
</section>
