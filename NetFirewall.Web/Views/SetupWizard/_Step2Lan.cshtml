@model NetFirewall.Web.Models.Setup.Step2ViewModel
@using NetFirewall.Web.Models

<header class="mb-5">
    <h2 class="text-lg font-semibold">Step 2 — LAN &amp; DHCP</h2>
    <p class="text-sm mt-1" style="color: var(--surface-fg-muted);">
        For every interface marked LAN in step 1, choose its address space and the DHCP range it should hand out to clients.
        Defaults are sensible if you have no preference.
    </p>
</header>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState["Lans"]?.Errors.Count > 0)
{
    <div class="mb-5 rounded-md border-l-2 px-3 py-2 text-sm"
         style="background-color: var(--feedback-danger-bg); color: var(--feedback-danger-fg); border-color: var(--feedback-danger-bd);">
        @foreach (var err in ViewData.ModelState["Lans"]!.Errors) { <p>@err.ErrorMessage</p> }
    </div>
}

<form method="post" action="/setup/wizard/step/2">
    @Html.AntiForgeryToken()

    @if (Model.Lans.Count == 0)
    {
        <div class="rounded-lg border p-6 text-sm text-center"
             style="border-color: var(--surface-border); color: var(--surface-fg-muted);">
            No LAN interfaces selected in step 1 — go back and mark at least one as LAN, or skip this step.
        </div>
    }
    else
    {
        <div class="space-y-5">
            @for (var i = 0; i < Model.Lans.Count; i++)
            {
                var lan = Model.Lans[i];
                <div class="rounded-lg border p-4" style="border-color: var(--surface-border);">
                    <input type="hidden" name="Lans[@i].InterfaceName" value="@lan.InterfaceName" />

                    <div class="flex items-center justify-between mb-3">
                        <div>
                            <p class="font-mono text-sm font-medium">@lan.InterfaceName</p>
                            <p class="text-xs" style="color: var(--surface-fg-muted);">LAN configuration</p>
                        </div>
                        <label class="flex items-center gap-2 text-xs">
                            <input type="checkbox" name="Lans[@i].EnableDhcp" value="true" @(lan.EnableDhcp ? "checked" : "") class="h-4 w-4 rounded" />
                            <span>Hand out DHCP leases</span>
                        </label>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].ServerIp", Label = "Server IP (gateway)", Required = true, Value = lan.ServerIp,
                            Placeholder = "192.168.99.1"
                        })
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].SubnetMask", Label = "Subnet mask", Required = true, Value = lan.SubnetMask,
                            Placeholder = "255.255.255.0"
                        })
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].NetworkCidr", Label = "Network CIDR", Required = true, Value = lan.NetworkCidr,
                            Placeholder = "192.168.99.0/24",
                            Pattern = @"^(\d{1,3}\.){3}\d{1,3}/\d{1,2}$"
                        })
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].DomainName", Label = "Domain name (optional)", Value = lan.DomainName,
                            Placeholder = "lan.local"
                        })
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].DhcpRangeStart", Label = "DHCP range start", Required = true, Value = lan.DhcpRangeStart,
                            Placeholder = "192.168.99.10"
                        })
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].DhcpRangeEnd", Label = "DHCP range end", Required = true, Value = lan.DhcpRangeEnd,
                            Placeholder = "192.168.99.250"
                        })
                        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                            Name = $"Lans[{i}].LeaseTime", Label = "Lease time (seconds)", Kind = FormFieldKind.Number, Required = true,
                            Value = lan.LeaseTime.ToString(), Min = "60", Max = "604800",
                            Help = "86400 = 1 day · 604800 = 7 days"
                        })
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-6 pt-4 border-t flex items-center justify-between gap-2"
         style="border-color: var(--surface-border);">
        <form method="post" action="/setup/wizard/back/2" class="inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-ghost">← Back</button>
        </form>
        <button type="submit" class="btn btn-primary">
            Continue
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </button>
    </div>
</form>
