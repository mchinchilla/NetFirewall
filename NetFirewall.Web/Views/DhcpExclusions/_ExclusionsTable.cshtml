@model IReadOnlyList<NetFirewall.Models.Dhcp.DhcpExclusion>
@{
    var subnetId = (Guid)ViewBag.SubnetId;
}

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center text-surface-fg-muted">
        No exclusions yet. Add one to keep an IP (or a small range) out of the auto-assignment pool.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-surface-fg-muted">
                    <th class="px-5 py-2 font-medium">Range</th>
                    <th class="px-5 py-2 font-medium">Reason</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y border-surface-border">
                @foreach (var e in Model.OrderBy(x => x.IpStart?.ToString()))
                {
                    <tr>
                        <td class="px-5 py-3 font-mono text-xs">
                            @e.IpStart@(e.IpEnd != null ? $"  →  {e.IpEnd}" : "")
                        </td>
                        <td class="px-5 py-3 text-xs text-surface-fg-muted">@(e.Reason ?? "—")</td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Dhcp/Subnets/@subnetId/Exclusions/edit/@e.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit exclusion')">Edit</button>
                                @{
                                    var msg = $"Delete exclusion {e.IpStart}{(e.IpEnd != null ? $" → {e.IpEnd}" : "")}? The IPs will rejoin the pool.";
                                }
                                <button type="button" class="btn btn-ghost text-xs text-feedback-danger-fg"
                                        hx-post="/Dhcp/Subnets/@subnetId/Exclusions/delete/@e.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete exclusion?',
                                                message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete',
                                                level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
