@{
    ViewData["Title"] = "Firewall — Filter rules";
    Layout = "_Layout";
}

<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);"
     x-data="{ chain: '' }">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">Firewall</p>
        <h1 class="text-2xl font-semibold tracking-tight">Filter rules</h1>
        <p class="text-sm mt-1 text-surface-fg-muted">
            Stateful packet filter — input / forward / output chains. Lower priority = checked first.
        </p>
    </div>
    <div class="flex items-center gap-2">
        <label class="text-xs flex items-center gap-2">
            Chain
            <select x-model="chain"
                    @@change="htmx.trigger(document.getElementById('filter-rules-table'), 'manual-refresh')"
                    class="input py-1 text-xs">
                <option value="">All</option>
                <option value="input">Input</option>
                <option value="forward">Forward</option>
                <option value="output">Output</option>
            </select>
        </label>
        <button type="button" class="btn btn-primary"
                hx-get="/Firewall/FilterRules/edit"
                hx-target="#drawer-body" hx-swap="innerHTML"
                @@click="$store.drawer.openRaw('Add filter rule')">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            Add rule
        </button>
    </div>

    <section class="card mt-3 w-full" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
        <div id="filter-rules-table"
             hx-get="/Firewall/FilterRules/table"
             :hx-vals="JSON.stringify({ chain })"
             hx-trigger="load, refreshFilterRules from:body, manual-refresh"
             hx-swap="innerHTML">
            <div class="text-sm py-8 text-center text-surface-fg-muted">Loading…</div>
        </div>
    </section>
</div>
