@model IReadOnlyList<NetFirewall.Models.Firewall.FwFilterRule>
@{
    var ifaceNames = (IDictionary<Guid, string>)(ViewBag.InterfaceNames ?? new Dictionary<Guid, string>());

    string ActionBadge(string action) => action switch
    {
        "accept" => "var(--feedback-success-bg)",
        "drop"   => "var(--feedback-danger-bg)",
        "reject" => "var(--feedback-warning-bg)",
        _        => "var(--feedback-info-bg)"
    };
    string ActionColor(string action) => action switch
    {
        "accept" => "var(--feedback-success-fg)",
        "drop"   => "var(--feedback-danger-fg)",
        "reject" => "var(--feedback-warning-fg)",
        _        => "var(--feedback-info-fg)"
    };
}

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">
        No filter rules in this chain. Click <span class="font-medium" style="color: var(--surface-fg);">Add rule</span> to create one.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Pri</th>
                    <th class="px-5 py-2 font-medium">Chain</th>
                    <th class="px-5 py-2 font-medium">Action</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Match</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Interfaces</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var r in Model.OrderBy(x => x.Chain).ThenBy(x => x.Priority))
                {
                    <tr>
                        <td class="px-5 py-3 font-mono text-xs">@r.Priority</td>
                        <td class="px-5 py-3 font-mono text-xs">@r.Chain</td>
                        <td class="px-5 py-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium uppercase"
                                  style="background-color: @ActionBadge(r.Action); color: @ActionColor(r.Action);">@r.Action</span>
                        </td>
                        <td class="px-5 py-3 hidden md:table-cell text-xs" style="color: var(--surface-fg-muted);">
                            @if (!string.IsNullOrEmpty(r.Description)) { <span class="block font-medium" style="color: var(--surface-fg);">@r.Description</span> }
                            @{
                                var match = new List<string>();
                                if (!string.IsNullOrEmpty(r.Protocol)) match.Add($"proto {r.Protocol}");
                                if (r.DestinationPorts is { Length: > 0 }) match.Add($"dport {string.Join(",", r.DestinationPorts)}");
                                if (r.SourceAddresses is { Length: > 0 }) match.Add($"src {string.Join(",", r.SourceAddresses)}");
                                if (r.DestinationAddresses is { Length: > 0 }) match.Add($"dst {string.Join(",", r.DestinationAddresses)}");
                                if (r.ConnectionState is { Length: > 0 }) match.Add($"state {string.Join(",", r.ConnectionState)}");
                                if (!string.IsNullOrEmpty(r.RateLimit)) match.Add($"rate {r.RateLimit}");
                            }
                            <span class="font-mono">@(match.Count == 0 ? "any" : string.Join(" · ", match))</span>
                        </td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs font-mono" style="color: var(--surface-fg-muted);">
                            @{
                                var inName  = r.InterfaceInId  is { } iin && ifaceNames.TryGetValue(iin, out var n1) ? n1 : null;
                                var outName = r.InterfaceOutId is { } iou && ifaceNames.TryGetValue(iou, out var n2) ? n2 : null;
                            }
                            in: @(inName ?? "any") · out: @(outName ?? "any")
                        </td>
                        <td class="px-5 py-3">
                            @if (r.Enabled)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Enabled</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">Disabled</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Firewall/FilterRules/edit/@r.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit filter rule')">Edit</button>
                                @{ var msg = $"Delete {r.Chain}/{r.Action} rule (priority {r.Priority})? Apply firewall after to push the change."; }
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Firewall/FilterRules/delete/@r.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete rule?',
                                                message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete',
                                                level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
