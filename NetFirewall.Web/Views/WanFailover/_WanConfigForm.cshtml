@model NetFirewall.Web.Models.Network.WanConfigFormViewModel
@using NetFirewall.Web.Models

<form id="wan-config-form" hx-post="/Network/Wan/config" hx-target="this" hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    <input type="hidden" name="InterfaceId" value="@Model.InterfaceId" />
    <input type="hidden" name="InterfaceName" value="@Model.InterfaceName" />

    <div class="space-y-4">
        <div class="rounded-lg p-3 text-sm bg-surface-muted">
            Probe config for <span class="font-mono font-semibold">@Model.InterfaceName</span>.
            The daemon pings these targets every cycle; failover follows the priority + thresholds below.
        </div>

        <div class="grid grid-cols-2 gap-3">
            <div class="space-y-1.5">
                <label class="block text-xs font-medium text-surface-fg">Priority <span class="text-feedback-danger-fg">*</span></label>
                <input type="number" name="@nameof(Model.Priority)" value="@Model.Priority" min="1" max="1000"
                       class="input" required />
                <p class="text-xs text-surface-fg-muted">Lower = preferred. 1 = primary.</p>
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-medium text-surface-fg">Probe fwmark</label>
                <input type="number" name="@nameof(Model.ProbeFwmark)" value="@(Model.ProbeFwmark?.ToString() ?? "")"
                       min="1" max="4294967295" class="input font-mono" placeholder="256" />
                <p class="text-xs text-surface-fg-muted">Decimal (256 = 0x100, 512 = 0x200). Empty = legacy <span class="font-mono">-I</span> probing.</p>
            </div>
        </div>

        <div class="space-y-1.5">
            <label class="block text-xs font-medium text-surface-fg">Monitor targets</label>
            <textarea name="@nameof(Model.MonitorTargets)" rows="2" class="input font-mono"
                      placeholder="8.8.8.8, 1.1.1.1">@Model.MonitorTargets</textarea>
            <p class="text-xs text-surface-fg-muted">IPs to ping (comma/space separated). Empty = ping this interface's gateway.</p>
        </div>

        <div class="grid grid-cols-2 gap-3">
            <div class="space-y-1.5">
                <label class="block text-xs font-medium text-surface-fg">Failover after <span class="text-feedback-danger-fg">*</span></label>
                <input type="number" name="@nameof(Model.FailoverThreshold)" value="@Model.FailoverThreshold" min="1" max="100"
                       class="input" required />
                <p class="text-xs text-surface-fg-muted">Consecutive failed cycles → down.</p>
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-medium text-surface-fg">Recover after <span class="text-feedback-danger-fg">*</span></label>
                <input type="number" name="@nameof(Model.RecoveryThreshold)" value="@Model.RecoveryThreshold" min="1" max="100"
                       class="input" required />
                <p class="text-xs text-surface-fg-muted">Consecutive OK cycles → back up.</p>
            </div>
        </div>

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.Enabled), Label = "Enabled", Kind = FormFieldKind.Checkbox,
            Value = Model.Enabled ? "true" : "false",
            Help = "Disabling stops probing this WAN — it won't be a failover candidate."
        })
    </div>

    <div class="mt-6 pt-4 border-t flex items-center justify-end gap-2 border-surface-border">
        <button type="button" class="btn btn-ghost" @@click="$store.drawer.close()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save config</button>
    </div>
</form>
