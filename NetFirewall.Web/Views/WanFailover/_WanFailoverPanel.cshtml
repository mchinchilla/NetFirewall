@model NetFirewall.Web.Models.Network.WanFailoverPanelViewModel
@using NetFirewall.Web.Models.Network

@if (Model.NotConfigured)
{
    <div class="card">
        <div class="flex items-start gap-3">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full"
                  style="background-color: var(--feedback-warning-bg); color: var(--feedback-warning-fg);">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            </span>
            <div>
                <h2 class="text-base font-semibold">Failover not configured</h2>
                <p class="text-sm mt-1 text-surface-fg-muted">
                    No WAN health-probe config rows exist, so the daemon isn't monitoring any WAN and
                    <span class="font-medium text-surface-fg">automatic failover is inactive</span>.
                    Assign <span class="font-mono">primary_wan</span> / <span class="font-mono">secondary_wan</span>
                    roles to your WAN interfaces and re-run migrations to auto-seed this, or add a config row per WAN.
                </p>
            </div>
        </div>
    </div>
}
else
{
    @* Mode banner: auto vs pinned override. *@
    <div class="card mb-4 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3">
            @if (Model.IsOverridden)
            {
                <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold"
                      style="background-color: var(--feedback-warning-bg); color: var(--feedback-warning-fg);">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
                    Pinned
                </span>
                <p class="text-sm">
                    <span class="font-semibold">@Model.OverrideInterfaceName</span> is pinned as the active WAN
                    @if (!string.IsNullOrEmpty(Model.OverrideSetBy)) { <span class="text-surface-fg-muted">by @Model.OverrideSetBy</span> }
                    <span class="text-surface-fg-muted">— automatic priority failover is paused until it goes down.</span>
                </p>
            }
            else
            {
                <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold"
                      style="background-color: var(--accent-soft); color: var(--accent);">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
                    Automatic
                </span>
                <p class="text-sm text-surface-fg-muted">
                    The lowest-priority healthy WAN is selected automatically.
                </p>
            }
        </div>
        @if (Model.IsOverridden)
        {
            <button type="button" class="btn btn-ghost text-sm"
                    hx-post="/Network/Wan/clear-override"
                    hx-swap="none"
                    hx-trigger="confirmed-clear"
                    @@click.prevent="(async () => {
                        const ok = await $store.confirm.ask({
                            title: 'Return to automatic?',
                            message: 'Clear the manual pin and let priority-based failover choose the active WAN again.',
                            confirmLabel: 'Return to auto',
                            level: 'default'
                        });
                        if (ok) htmx.trigger($el, 'confirmed-clear');
                    })()">
                Return to automatic
            </button>
        }
    </div>

    @* WAN cards. *@
    <div class="grid gap-4 md:grid-cols-2">
        @foreach (var w in Model.Wans)
        {
            <div class="card">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <div class="flex items-center gap-2">
                            <h3 class="text-base font-semibold font-mono truncate">@w.Name</h3>
                            @if (w.IsActive)
                            {
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-semibold"
                                      style="background-color: var(--accent-soft); color: var(--accent);">Active</span>
                            }
                            @if (w.IsPinned)
                            {
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-semibold"
                                      style="background-color: var(--feedback-warning-bg); color: var(--feedback-warning-fg);">Pinned</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(w.Role))
                        {
                            <p class="text-xs mt-0.5 text-surface-fg-muted">@w.Role.Replace("_", " ")</p>
                        }
                    </div>
                    @* Health dot. *@
                    <span class="inline-flex items-center gap-1.5 text-sm font-medium shrink-0"
                          style="color: @(w.IsUp ? "var(--feedback-success-fg)" : "var(--feedback-danger-fg)");">
                        <span class="h-2.5 w-2.5 rounded-full"
                              style="background-color: @(w.IsUp ? "var(--feedback-success-fg)" : "var(--feedback-danger-fg)");"></span>
                        @(w.IsUp ? "Up" : "Down")
                    </span>
                </div>

                <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1.5 text-sm">
                    <dt class="text-surface-fg-muted">Last probe</dt>
                    <dd class="text-right">@(w.LastRttMs is { } rtt ? $"{rtt:0.#} ms" : "—")</dd>
                    <dt class="text-surface-fg-muted">Target</dt>
                    <dd class="text-right font-mono text-xs truncate">@(w.LastTarget ?? "gateway")</dd>
                    @if (!w.IsUp && w.ConsecutiveFailures > 0)
                    {
                        <dt class="text-surface-fg-muted">Failures</dt>
                        <dd class="text-right" style="color: var(--feedback-danger-fg);">@w.ConsecutiveFailures consecutive</dd>
                    }
                    else if (w.IsUp && w.ConsecutiveSuccesses > 0)
                    {
                        <dt class="text-surface-fg-muted">Successes</dt>
                        <dd class="text-right">@w.ConsecutiveSuccesses consecutive</dd>
                    }
                    @if (!string.IsNullOrEmpty(w.LastError))
                    {
                        <dt class="text-surface-fg-muted">Last error</dt>
                        <dd class="text-right text-xs truncate" style="color: var(--feedback-danger-fg);" title="@w.LastError">@w.LastError</dd>
                    }
                </dl>

                <div class="mt-4 pt-3 border-t flex items-center justify-end gap-2 border-surface-border">
                    <button type="button" class="btn btn-ghost text-sm"
                            hx-get="/Network/Wan/config/@w.InterfaceId"
                            hx-target="#drawer-body" hx-swap="innerHTML"
                            @@click="$store.drawer.openRaw('Probe config — @w.Name')">
                        Configure
                    </button>
                    @if (!w.IsActive)
                    {
                        <button type="button" class="btn btn-primary text-sm"
                                hx-post="/Network/Wan/swap/@w.InterfaceId"
                                hx-swap="none"
                                hx-trigger="confirmed-swap"
                                data-name="@w.Name"
                                data-up="@(w.IsUp ? "1" : "0")"
                                @@click.prevent="(async () => {
                                    const el = $event.currentTarget;
                                    const name = el.dataset.name;
                                    const isUp = el.dataset.up === '1';
                                    const ok = await $store.confirm.ask({
                                        title: 'Switch active WAN?',
                                        message: isUp
                                            ? ('Make ' + name + ' the active default route and pin it. Active connections may briefly drop while routing changes.')
                                            : ('⚠ ' + name + ' is currently DOWN. Forcing it active will likely black-hole traffic until it recovers. Continue anyway?'),
                                        confirmLabel: 'Switch to ' + name,
                                        level: isUp ? 'warning' : 'danger'
                                    });
                                    if (ok) htmx.trigger(el, 'confirmed-swap');
                                })()">
                            Make active
                        </button>
                    }
                </div>
            </div>
        }
    </div>

    @* Recent transitions timeline. *@
    <div class="card mt-4">
        <h2 class="text-base font-semibold mb-3">Recent activity</h2>
        @if (Model.RecentEvents.Count == 0)
        {
            <p class="text-sm text-surface-fg-muted">No failover events recorded yet.</p>
        }
        else
        {
            <ul class="divide-y border-surface-border">
                @foreach (var e in Model.RecentEvents)
                {
                    var (label, color) = e.EventType switch
                    {
                        "up"       => ("recovered", "var(--feedback-success-fg)"),
                        "down"     => ("went down", "var(--feedback-danger-fg)"),
                        "failover" => ("became active", "var(--accent)"),
                        "demoted"  => ("demoted", "var(--surface-fg-muted)"),
                        _          => (e.EventType, "var(--surface-fg-muted)"),
                    };
                    <li class="flex items-center justify-between gap-3 py-2 text-sm">
                        <span>
                            <span class="font-mono font-medium">@e.InterfaceName</span>
                            <span style="color: @color;"> @label</span>
                        </span>
                        <time class="text-xs text-surface-fg-muted shrink-0" datetime="@e.OccurredAt.ToString("o")">
                            @e.OccurredAt.ToLocalTime().ToString("MMM d, HH:mm:ss")
                        </time>
                    </li>
                }
            </ul>
        }
    </div>
}
