@model NetFirewall.Web.Models.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Sign in";
}

<div>
    @* The step content swaps in place (HTMX) — see _LoginForm/_LoginTotpForm.
       _SystemInfoCard stays OUTSIDE the swap target so its lazy geo fragment
       isn't re-fetched on every failed attempt or step change. *@
    @await Html.PartialAsync("_LoginForm", Model)

    <div class="mt-8">
        @await Html.PartialAsync("_SystemInfoCard")
    </div>
</div>
