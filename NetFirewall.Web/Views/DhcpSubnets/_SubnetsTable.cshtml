@model IReadOnlyList<NetFirewall.Models.Dhcp.DhcpSubnet>

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">
        No subnets configured yet. Click <span class="font-medium" style="color: var(--surface-fg);">Add subnet</span> to create one,
        or run the <a href="/setup/wizard" class="hover:underline" style="color: var(--accent);">setup wizard</a>.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Name</th>
                    <th class="px-5 py-2 font-medium">Network</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Router</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Lease</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="px-5 py-3 font-medium">@s.Name</td>
                        <td class="px-5 py-3 font-mono text-xs">@s.Network</td>
                        <td class="px-5 py-3 hidden md:table-cell font-mono text-xs">@(s.Router?.ToString() ?? "—")</td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs" style="color: var(--surface-fg-muted);">
                            @(s.DefaultLeaseTime / 3600)h / @(s.MaxLeaseTime / 3600)h
                        </td>
                        <td class="px-5 py-3">
                            @if (s.Enabled)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Enabled</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">Disabled</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <a href="/Dhcp/Subnets/@s.Id/Pools" class="btn btn-ghost text-xs">Pools →</a>
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Dhcp/Subnets/edit/@s.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit @s.Name')">Edit</button>
                                @{
                                    var delMsg = $"Delete subnet '{s.Name}' ({s.Network})? Pools, exclusions and reservations bound to it will be cascaded.";
                                }
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Dhcp/Subnets/delete/@s.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@delMsg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete subnet?',
                                                message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete',
                                                level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
