@{
    ViewData["Title"] = "DHCP — Subnets";
    Layout = "_Layout";
}

<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">DHCP</p>
        <h1 class="text-2xl font-semibold tracking-tight">Subnets</h1>
        <p class="text-sm mt-1 text-surface-fg-muted">
            Each subnet is a self-contained DHCP scope with its own pool ranges, options and DDNS settings.
        </p>
    </div>
    <button type="button" class="btn btn-primary"
            hx-get="/Dhcp/Subnets/edit"
            hx-target="#drawer-body"
            hx-swap="innerHTML"
            @@click="$store.drawer.openRaw('Add subnet')">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Add subnet
    </button>
</div>

<section class="card" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
    <div id="subnets-table"
         hx-get="/Dhcp/Subnets/table"
         hx-trigger="load, refreshSubnets from:body"
         hx-swap="innerHTML">
         Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
    </div>
</section>
