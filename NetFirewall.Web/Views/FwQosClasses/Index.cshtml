@{
    ViewData["Title"] = "Firewall — QoS classes";
    Layout = "_Layout";
    var config = (NetFirewall.Models.Firewall.FwQosConfig)ViewBag.Config;
    var ifaceName = (string)ViewBag.InterfaceName;
}
<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">
            <a href="/Firewall/Qos" class="hover:underline text-accent">Firewall · QoS</a>
            <span class="text-surface-fg-muted"> / </span>
            @ifaceName
        </p>
        <h1 class="text-2xl font-semibold tracking-tight">QoS classes — @ifaceName</h1>
        <p class="text-sm mt-1 text-surface-fg-muted">
            Total budget: <span class="font-mono">@config.TotalBandwidthMbps Mbps</span>.
            Sum of guaranteed values must not exceed it; ceilings can overlap (HTB borrowing).
        </p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
        @await Html.PartialAsync("_TableSearch", new TableSearchModel { TableId = "qos-classes-table", Placeholder = "Filter by class name…", ClientSide = true })
        <button type="button" class="btn btn-primary"
                hx-get="/Firewall/Qos/@config.Id/Classes/edit"
                hx-target="#drawer-body" hx-swap="innerHTML"
                @@click="$store.drawer.openRaw('Add class')">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            Add class
        </button>
    </div>
</div>
<section class="card" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
    <div id="qos-classes-table"
         hx-get="/Firewall/Qos/@config.Id/Classes/table"
         hx-trigger="load, refreshQosClasses from:body"
         hx-swap="innerHTML">
         Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
    </div>
</section>
