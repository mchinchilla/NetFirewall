@model NetFirewall.Services.Network.NetworkObjectUsage
@{
    var name = (string)ViewBag.ObjectName;
    var sections = new (string Title, IReadOnlyList<NetFirewall.Services.Network.UsageEntry> Entries, string ListUrl)[]
    {
        ("Filter rules",  Model.FilterRules,  "/Firewall/FilterRules"),
        ("Port forwards", Model.PortForwards, "/Firewall/PortForwards"),
        ("NAT rules",     Model.NatRules,     "/Firewall/NatRules"),
        ("Mangle rules",  Model.MangleRules,  "/Firewall/MangleRules"),
        ("Parent groups", Model.ParentGroups, "/Network/Objects"),
    };
}

@if (Model.TotalCount == 0)
{
    <div class="text-xs px-3 py-2 rounded"
         style="background: color-mix(in srgb, var(--surface-fg-muted) 8%, transparent); color: var(--surface-fg-muted);">
        <span class="font-medium" style="color: var(--surface-fg);">@name</span> is not referenced by any rule or group. Safe to edit or delete.
    </div>
}
else
{
    <div class="rounded border-l-2 px-3 py-2 text-xs space-y-2"
         style="background: color-mix(in srgb, var(--feedback-warning-fg) 8%, transparent); border-color: var(--feedback-warning-bd);">
        <p>
            <span class="font-semibold" style="color: var(--feedback-warning-fg);">@Model.TotalCount</span>
            reference@(Model.TotalCount == 1 ? "" : "s") to <span class="font-mono font-medium">@name</span>.
            Edits propagate at next apply; delete will silently break these.
        </p>

        @foreach (var (title, entries, listUrl) in sections.Where(s => s.Entries.Count > 0))
        {
            <details class="space-y-1">
                <summary class="cursor-pointer font-medium hover:underline" style="color: var(--surface-fg);">
                    @title (@entries.Count)
                </summary>
                <ul class="space-y-0.5 ml-4 mt-1">
                    @foreach (var e in entries)
                    {
                        <li style="color: var(--surface-fg-muted);">
                            <a class="hover:underline" style="color: var(--accent);" href="@listUrl">@e.Description</a>
                            <span class="font-mono"> · @e.Field</span>
                        </li>
                    }
                </ul>
            </details>
        }
    </div>
}
