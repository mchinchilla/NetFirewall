@{
    ViewData["Title"] = "Network — Objects";
    Layout = "_Layout";
}

<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">Network</p>
        <h1 class="text-2xl font-semibold tracking-tight">Objects</h1>
        <p class="text-sm mt-1 text-surface-fg-muted">
            Named, reusable address aliases. Reference them in firewall rule source/destination instead of literal CIDRs — change the value once, every rule picks it up at next apply.
        </p>
    </div>
    <button type="button" class="btn btn-primary"
            hx-get="/Network/Objects/edit"
            hx-target="#drawer-body" hx-swap="innerHTML"
            @@click="$store.drawer.openRaw('Add object')">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Add object
    </button>
</div>

<section class="card" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
    <div id="network-objects-table"
         hx-get="/Network/Objects/table"
         hx-trigger="load, refreshNetworkObjects from:body"
         hx-swap="innerHTML">
        <div class="text-sm py-8 text-center text-surface-fg-muted">Loading…</div>
    </div>
</section>
