@model IReadOnlyList<NetFirewall.Models.Network.NetworkObject>
@using NetFirewall.Models.Network

@if (Model.Count == 0)
{
    <p class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">
        No objects yet. Click <span class="font-medium" style="color: var(--surface-fg);">Add object</span> to create your first one.
    </p>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Name</th>
                    <th class="px-5 py-2 font-medium">Type</th>
                    <th class="px-5 py-2 font-medium">Value / members</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Description</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var o in Model)
                {
                    var typeBg = o.Type switch
                    {
                        NetworkObjectTypes.Host    => "var(--feedback-info-bg)",
                        NetworkObjectTypes.Network => "var(--accent-soft)",
                        NetworkObjectTypes.Range   => "var(--feedback-warning-bg)",
                        _                          => "var(--surface-muted)"
                    };
                    var typeFg = o.Type switch
                    {
                        NetworkObjectTypes.Host    => "var(--feedback-info-fg)",
                        NetworkObjectTypes.Network => "var(--accent)",
                        NetworkObjectTypes.Range   => "var(--feedback-warning-fg)",
                        _                          => "var(--surface-fg-muted)"
                    };
                    <tr>
                        <td class="px-5 py-3 font-mono font-medium">@o.Name</td>
                        <td class="px-5 py-3">
                            <span class="badge" style="background: @typeBg; color: @typeFg;">@o.Type</span>
                        </td>
                        <td class="px-5 py-3 font-mono text-xs">
                            @if (o.Type == NetworkObjectTypes.Group)
                            {
                                <span style="color: var(--surface-fg-muted);">
                                    @(o.Members?.Count ?? 0) member@((o.Members?.Count ?? 0) == 1 ? "" : "s"):
                                </span>
                                @if (o.Members is { Count: > 0 })
                                {
                                    @string.Join(", ", o.Members.Take(5).Select(m => m.Name))
                                    @if (o.Members.Count > 5) { <span style="color: var(--surface-fg-muted);"> · +@(o.Members.Count - 5) more</span> }
                                }
                            }
                            else
                            {
                                @o.Value
                            }
                        </td>
                        <td class="px-5 py-3 hidden md:table-cell text-xs" style="color: var(--surface-fg-muted);">@(o.Description ?? "—")</td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Network/Objects/edit/@o.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit @o.Name')">Edit</button>
                                @{ var msg = $"Delete object '{o.Name}'? Any firewall rules referencing it by name will silently skip the reference at next apply (the resolver logs a warning)."; }
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Network/Objects/delete/@o.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete object?', message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete', level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
