@*
    Mode-aware labels for the WireGuard page. Pass the server mode string as the
    model ("server" | "client"). Centralizes the relabeling so the page subtitle,
    the peers section, and the peers table all speak the same language.
*@
@model string
@{
    var isClient = string.Equals(Model, "client", StringComparison.OrdinalIgnoreCase);
    // Exposed to the parent view via ViewData so a single PartialAsync call can
    // surface several strings without a typed bag.
    ViewData["wg.roleLabel"]       = isClient ? "Client" : "Server";
    ViewData["wg.peersTitle"]      = isClient ? "Remote server (upstream tunnel)" : "Peers (road-warriors / sites)";
    ViewData["wg.peersSubtitle"]   = isClient
        ? "This firewall dials OUT to the server below. Marked LAN devices egress through it."
        : "Each peer = one inbound client (laptop, phone, or another site).";
    ViewData["wg.addPeerLabel"]    = isClient ? "Set remote server" : "Add peer";
}
