@{
    ViewData["Title"] = "VPN — WireGuard";
    Layout = "_Layout";
    var server = (NetFirewall.Models.Vpn.WgServer?)ViewBag.Server;
    var form = (NetFirewall.Web.Models.Vpn.WgServerFormViewModel)ViewBag.Form;
}
<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">VPN</p>
        <h1 class="text-2xl font-semibold tracking-tight">WireGuard</h1>
        <p class="text-sm mt-1 text-surface-fg-muted">
            One interface, two jobs: <span class="font-medium">tunnels</span> this firewall keeps up (upstream egress, site-to-site) and <span class="font-medium">clients</span> that connect in (laptops, phones). Client keys are generated on-device by the daemon and the private half is shown <span class="font-medium">once</span> — we never persist it.
        </p>
    </div>
    @if (server is not null)
    {
        <div class="flex items-center gap-2">
            <button type="button" class="btn btn-ghost"
                    hx-post="/Vpn/WireGuard/stop" hx-trigger="confirmed-stop"
                    @@click.prevent="(async () => {
                        const ok = await $store.confirm.ask({
                            title: 'Stop WireGuard?',
                            message: 'Brings down @server.Name. Active client sessions will drop until you bring it back up.',
                            confirmLabel: 'Stop now',
                            level: 'warning'
                        });
                        if (ok) htmx.trigger($el, 'confirmed-stop');
                    })()">Stop</button>
            <button type="button" class="btn btn-ghost"
                    hx-post="/Vpn/WireGuard/apply" hx-trigger="confirmed-apply"
                    title="Only writes the wg config + brings the interface up (no firewall/routing)."
                    @@click.prevent="(async () => {
                        const ok = await $store.confirm.ask({
                            title: 'Apply WireGuard config only?',
                            message: 'Writes /etc/wireguard/@(server.Name).conf and brings the interface up (or hot-reloads peers via wg syncconf). Does NOT re-apply firewall rules or policy routing.',
                            confirmLabel: 'Apply tunnel',
                            level: 'default'
                        });
                        if (ok) htmx.trigger($el, 'confirmed-apply');
                    })()">Apply tunnel only</button>
            <button type="button" class="btn btn-primary"
                    hx-post="/Vpn/WireGuard/apply-all" hx-trigger="confirmed-apply-all"
                    title="Applies firewall rules → tunnel → policy routing, in the right order."
                    @@click.prevent="(async () => {
                        const ok = await $store.confirm.ask({
                            title: 'Apply full VPN config?',
                            message: 'Applies in order: firewall rules (nft) → WireGuard tunnel → policy routing (ip rule/route). This is what you want after changing egress devices or peers.',
                            confirmLabel: 'Apply VPN',
                            level: 'default'
                        });
                        if (ok) htmx.trigger($el, 'confirmed-apply-all');
                    })()">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                Apply VPN
            </button>
        </div>
    }
</div>

@* ----- Import from disk ----- *@
<section class="card mb-4" style="animation: var(--animate-slide-up); animation-delay: 30ms;">
    <header class="flex items-baseline justify-between mb-3">
        <h2 class="text-base font-semibold">Import from <code>/etc/wireguard</code></h2>
        <button type="button" class="btn btn-ghost text-xs"
                hx-get="/Vpn/WireGuard/importables"
                hx-target="#wg-import-picker"
                hx-swap="innerHTML">
            Scan
        </button>
    </header>
    <div id="wg-import-picker" class="text-sm text-surface-fg-muted">
        Click <strong>Scan</strong> to list <code>.conf</code> files visible to the daemon.
    </div>
</section>

<div class="grid gap-4 grid-cols-1 xl:grid-cols-2">
    @* ----- Interface config ----- *@
    <section class="card" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
        <header class="flex items-baseline justify-between mb-4">
            <h2 class="text-base font-semibold">Interface</h2>
            @if (server is not null)
            {
                <button type="button" class="btn btn-ghost text-xs text-feedback-danger-fg"
                        hx-post="/Vpn/WireGuard/regenerate-keys"
                        hx-trigger="confirmed-regen"
                        @@click.prevent="(async () => {
                            const ok = await $store.confirm.ask({
                                title: 'Rotate server keys?',
                                message: 'EVERY existing client config will stop working. You will need to re-issue every peer config.',
                                confirmLabel: 'Rotate keys',
                                level: 'danger'
                            });
                            if (ok) htmx.trigger($el, 'confirmed-regen');
                        })()">Rotate keys</button>
            }
        </header>

        <form hx-post="/Vpn/WireGuard/save" hx-swap="none">
            @Html.AntiForgeryToken()
            @if (form.Id.HasValue) { <input type="hidden" name="Id" value="@form.Id" /> }

            <div class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                        Name = nameof(form.Name), Label = "Interface name", Required = true, Value = form.Name,
                        Placeholder = "wg0"
                    })
                    @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                        Name = nameof(form.ListenPort), Label = "UDP listen port", Kind = NetFirewall.Web.Models.FormFieldKind.Number,
                        Value = form.ListenPort.ToString(), Min = "0", Max = "65535",
                        Help = "Where inbound clients connect. 0 = don't accept inbound (dial-only interface). Independent of upstream tunnels — one interface can do both."
                    })
                </div>

                @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                    Name = nameof(form.AddressCidr), Label = "This interface's address (CIDR inside tunnel)", Required = true,
                    Value = form.AddressCidr, Placeholder = "10.10.0.1/24",
                    Help = "The wg0 IP inside the tunnel subnet."
                })

                @* Common extras. *@
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                        Name = nameof(form.Dns), Label = "DNS (optional)", Value = form.Dns,
                        Placeholder = "1.1.1.1, 9.9.9.9"
                    })
                    @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                        Name = nameof(form.Mtu), Label = "MTU (optional)", Kind = NetFirewall.Web.Models.FormFieldKind.Number,
                        Value = form.Mtu?.ToString(), Min = "1280", Max = "9000"
                    })
                </div>

                @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                    Name = nameof(form.TableOff), Label = "Table = off (let policy routing own the route)",
                    Kind = NetFirewall.Web.Models.FormFieldKind.Checkbox, Value = form.TableOff ? "true" : "false",
                    Help = "Keeps wg-quick from installing the tunnel's routes itself. Forced ON automatically while an enabled upstream tunnel exists — otherwise its 0.0.0.0/0 route would hijack the firewall's own outbound."
                })

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                        Name = nameof(form.PostUp), Label = "PostUp (optional)", Value = form.PostUp,
                        Placeholder = "sysctl -w net.ipv4.ip_forward=1"
                    })
                    @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                        Name = nameof(form.PostDown), Label = "PostDown (optional)", Value = form.PostDown
                    })
                </div>

                @await Html.PartialAsync("_FormField", new NetFirewall.Web.Models.FormFieldViewModel {
                    Name = nameof(form.Enabled), Label = "Enabled", Kind = NetFirewall.Web.Models.FormFieldKind.Checkbox,
                    Value = form.Enabled ? "true" : "false"
                })

                @if (server is not null)
                {
                    <div class="pt-3 border-t border-surface-border">
                        <p class="text-xs uppercase tracking-wider font-semibold mb-1 text-surface-fg-muted">Interface public key</p>
                        <p class="text-xs font-mono break-all p-2 rounded" style="background: color-mix(in srgb, var(--surface-fg-muted) 8%, transparent);">@server.PublicKey</p>
                        <p class="text-xs mt-1 text-surface-fg-muted">This firewall's identity — give it to the remote side of any tunnel and to inbound clients. The private key never leaves the daemon.</p>
                    </div>
                }
            </div>

            <div class="mt-4 flex items-center justify-end">
                <button type="submit" class="btn btn-primary">@(server is null ? "Create server (generates keys)" : "Save")</button>
            </div>
        </form>
    </section>

    @* ----- Live status ----- *@
    <section class="card" style="animation: var(--animate-slide-up); animation-delay: 120ms;"
             x-data="{ paused: false }">
        <header class="flex items-baseline justify-between mb-4">
            <h2 class="text-base font-semibold">Live status</h2>
            <button type="button" class="btn btn-ghost text-xs"
                    @@click="paused = !paused"
                    x-text="paused ? 'Resume polling' : 'Pause polling'"></button>
        </header>
        <div id="wg-status"
             hx-get="/Vpn/WireGuard/status"
             :hx-trigger="paused ? 'load, refreshWireGuard from:body' : 'load, every 10s, refreshWireGuard from:body'"
             hx-swap="innerHTML">
             Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
        </div>
    </section>
</div>

@* ----- Tunnels (upstream / site-to-site — links this firewall keeps up) ----- *@
<section class="card mt-4" style="animation: var(--animate-slide-up); animation-delay: 180ms;">
    <header class="flex items-baseline justify-between mb-4">
        <div>
            <h2 class="text-base font-semibold">Tunnels</h2>
            <p class="text-xs text-surface-fg-muted">Upstream egress and site-to-site links. Expected to stay connected — health-monitored, with alerts when the handshake goes stale.</p>
        </div>
        @if (server is not null)
        {
            <button type="button" class="btn btn-primary text-xs"
                    hx-get="/Vpn/WireGuard/Peers/edit?family=tunnels"
                    hx-target="#drawer-body" hx-swap="innerHTML"
                    @@click="$store.drawer.openRaw('Add tunnel')">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                Add tunnel
            </button>
        }
    </header>

    @if (server is null)
    {
        <p class="text-sm py-8 text-center text-surface-fg-muted">Save the interface config first — tunnels need an interface to attach to.</p>
    }
    else
    {
        <div id="wg-tunnels-table"
             hx-get="/Vpn/WireGuard/Peers/table?family=tunnels"
             hx-trigger="load, refreshWireGuardPeers from:body, refreshWireGuard from:body"
             hx-swap="innerHTML">
             Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
        </div>
    }
</section>

@* ----- VPN clients (road-warriors that connect in) ----- *@
<section class="card mt-4" style="animation: var(--animate-slide-up); animation-delay: 200ms;">
    <header class="flex items-baseline justify-between mb-4">
        <div>
            <h2 class="text-base font-semibold">VPN clients</h2>
            <p class="text-xs text-surface-fg-muted">Each client = one config (laptop, phone, etc). Offline clients are normal — they're never flagged as outages.</p>
        </div>
        @if (server is not null)
        {
            <button type="button" class="btn btn-primary text-xs"
                    hx-get="/Vpn/WireGuard/Peers/edit?family=clients"
                    hx-target="#drawer-body" hx-swap="innerHTML"
                    @@click="$store.drawer.openRaw('Add client')">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                Add client
            </button>
        }
    </header>

    @if (server is null)
    {
        <p class="text-sm py-8 text-center text-surface-fg-muted">Save the interface config first — clients need an interface to attach to.</p>
    }
    else
    {
        <div id="wg-clients-table"
             hx-get="/Vpn/WireGuard/Peers/table?family=clients"
             hx-trigger="load, refreshWireGuardPeers from:body, refreshWireGuard from:body"
             hx-swap="innerHTML">
             Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
        </div>
    }
</section>

@* ----- Egress devices (which LAN hosts route through the tunnel) ----- *@
@if (server is not null)
{
    <section class="card mt-4" style="animation: var(--animate-slide-up); animation-delay: 220ms;">
        <header class="mb-4">
            <h2 class="text-base font-semibold">Egress through this tunnel</h2>
            <p class="text-xs text-surface-fg-muted">Choose which LAN devices/subnets send their traffic out via @server.Name. The rest use the normal WAN(s).</p>
        </header>
        <div id="wg-egress-panel"
             hx-get="/Vpn/WireGuard/Egress/panel"
             hx-trigger="load, refreshWireGuard from:body"
             hx-swap="innerHTML">
             Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
        </div>
    </section>
}
