@model IReadOnlyList<NetFirewall.Models.Firewall.FwNatRule>
@{
    var ifaceNames = (IDictionary<Guid, string>)(ViewBag.InterfaceNames ?? new Dictionary<Guid, string>());
}
@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">No NAT rules configured.</div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Pri</th>
                    <th class="px-5 py-2 font-medium">Type</th>
                    <th class="px-5 py-2 font-medium">Source</th>
                    <th class="px-5 py-2 font-medium">Out interface</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">SNAT addr</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var n in Model.OrderBy(x => x.Priority))
                {
                    var ifname = n.OutputInterfaceId is { } id && ifaceNames.TryGetValue(id, out var x) ? x : "any";
                    <tr>
                        <td class="px-5 py-3 font-mono text-xs">@n.Priority</td>
                        <td class="px-5 py-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium uppercase"
                                  style="background-color: var(--accent-soft); color: var(--accent);">@n.Type</span>
                        </td>
                        <td class="px-5 py-3 font-mono text-xs">@n.SourceNetwork</td>
                        <td class="px-5 py-3 font-mono text-xs">@ifname</td>
                        <td class="px-5 py-3 hidden md:table-cell font-mono text-xs">@(n.SnatAddress?.ToString() ?? "—")</td>
                        <td class="px-5 py-3">
                            @if (n.Enabled)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Enabled</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">Disabled</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Firewall/NatRules/edit/@n.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit NAT rule')">Edit</button>
                                @{ var msg = $"Delete {n.Type} rule for {n.SourceNetwork}?"; }
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Firewall/NatRules/delete/@n.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete NAT rule?', message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete', level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
