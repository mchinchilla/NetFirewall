@model NetFirewall.Web.Models.Firewall.NatRuleFormViewModel
@using NetFirewall.Web.Models
@{
    var ifaces = (IReadOnlyList<NetFirewall.Models.Firewall.FwInterface>)(ViewBag.Interfaces ?? Array.Empty<NetFirewall.Models.Firewall.FwInterface>());
    var ifaceOptions = new List<FormFieldViewModel.SelectOption> { new("", "any") };
    foreach (var i in ifaces.Where(i => i.Type == "WAN"))
        ifaceOptions.Add(new(i.Id.ToString(), $"{i.Name} ({i.Role})"));
    if (ifaceOptions.Count == 1)
        foreach (var i in ifaces)
            ifaceOptions.Add(new(i.Id.ToString(), $"{i.Name} ({i.Type})"));
}
<form id="nat-rule-form" hx-post="/Firewall/NatRules/save" hx-target="this" hx-swap="outerHTML"
      x-data="{ type: '@Model.Type' }">
    @Html.AntiForgeryToken()
    @if (Model.Id.HasValue) { <input type="hidden" name="Id" value="@Model.Id" /> }

    <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.Type), Label = "Type", Kind = FormFieldKind.Select, Required = true,
                Value = Model.Type, AlpineModel = "type",
                Options = new[] {
                    new FormFieldViewModel.SelectOption("masquerade", "Masquerade (auto-pick interface IP)"),
                    new FormFieldViewModel.SelectOption("snat",       "SNAT (static address)")
                }
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.Priority), Label = "Priority", Kind = FormFieldKind.Number, Required = true,
                Value = Model.Priority.ToString(), Min = "0", Max = "10000"
            })
        </div>

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.Description), Label = "Description", Value = Model.Description,
            Placeholder = "Masquerade LAN to WAN1"
        })

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.SourceNetwork), Label = "Source network (CIDR)", Required = true,
            Value = Model.SourceNetwork,
            Placeholder = "192.168.10.0/24",
            Pattern = @"^(\d{1,3}\.){3}\d{1,3}/\d{1,2}$"
        })

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.OutputInterfaceId), Label = "Output interface", Kind = FormFieldKind.Select,
            Value = Model.OutputInterfaceId?.ToString(), Options = ifaceOptions
        })

        <div x-show="type === 'snat'" x-transition>
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = nameof(Model.SnatAddress), Label = "SNAT address", Value = Model.SnatAddress,
                Placeholder = "203.0.113.5",
                AlpineExtra = ":required=\"type === 'snat'\"",
                Help = "Static address used for the source rewrite."
            })
        </div>

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = nameof(Model.Enabled), Label = "Enabled", Kind = FormFieldKind.Checkbox,
            Value = Model.Enabled ? "true" : "false"
        })
    </div>

    <div class="mt-6 pt-4 border-t flex items-center justify-end gap-2 border-surface-border">
        <button type="button" class="btn btn-ghost" @@click="$store.drawer.close()">Cancel</button>
        <button type="submit" class="btn btn-primary">@(Model.Id.HasValue ? "Save" : "Create rule")</button>
    </div>
</form>
