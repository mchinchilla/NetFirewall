@model IReadOnlyList<NetFirewall.Models.Firewall.FwTrafficMark>

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">No marks defined yet.</div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Name</th>
                    <th class="px-5 py-2 font-medium">Mark value</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Route table</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Description</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var m in Model.OrderBy(x => x.MarkValue))
                {
                    <tr>
                        <td class="px-5 py-3 font-medium">@m.Name</td>
                        <td class="px-5 py-3 font-mono text-xs">@m.MarkValue · 0x@m.MarkValue.ToString("X")</td>
                        <td class="px-5 py-3 hidden md:table-cell font-mono text-xs">@(m.RouteTable ?? "—")</td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs" style="color: var(--surface-fg-muted);">@(m.Description ?? "—")</td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Firewall/TrafficMarks/edit/@m.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit mark')">Edit</button>
                                @{ var msg = $"Delete mark '{m.Name}' (0x{m.MarkValue:X})? Mangle rules and QoS classes referencing it will lose the binding."; }
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Firewall/TrafficMarks/delete/@m.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete mark?', message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete', level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
