@model IReadOnlyList<NetFirewall.Models.Dhcp.DhcpClass>

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center text-surface-fg-muted">
        No classes yet. Add one to start steering specific client groups.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-surface-fg-muted">
                    <th class="px-5 py-2 font-medium">Name</th>
                    <th class="px-5 py-2 font-medium">Match</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Boot</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Priority</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y border-surface-border">
                @foreach (var c in Model.OrderBy(x => x.Priority))
                {
                    <tr>
                        <td class="px-5 py-3 font-medium">@c.Name</td>
                        <td class="px-5 py-3 font-mono text-xs">@c.MatchType <span class="text-surface-fg-muted">·</span> @c.MatchValue</td>
                        <td class="px-5 py-3 hidden md:table-cell text-xs text-surface-fg-muted">
                            @if (c.NextServer != null || !string.IsNullOrEmpty(c.BootFilename))
                            {
                                <span>@(c.NextServer?.ToString() ?? "—") / @(c.BootFilename ?? "—")</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td class="px-5 py-3 hidden lg:table-cell">@c.Priority</td>
                        <td class="px-5 py-3">
                            @if (c.Enabled)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-feedback-success-bg text-feedback-success-fg">Enabled</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-surface-muted text-surface-fg-muted">Disabled</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Dhcp/Classes/edit/@c.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit @c.Name')">Edit</button>
                                @{ var msg = $"Delete class '{c.Name}'? Pool↔class associations are cascaded."; }
                                <button type="button" class="btn btn-ghost text-xs text-feedback-danger-fg"
                                        hx-post="/Dhcp/Classes/delete/@c.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete class?',
                                                message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete',
                                                level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
