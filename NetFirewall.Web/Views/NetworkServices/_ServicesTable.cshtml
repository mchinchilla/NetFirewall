@model IReadOnlyList<NetFirewall.Models.Network.NetworkService>

@if (Model.Count == 0)
{
    <p class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">No services in this view.</p>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Name</th>
                    <th class="px-5 py-2 font-medium">Protocol</th>
                    <th class="px-5 py-2 font-medium">Port</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Category</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Description</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @{
                    string ProtoColor(string p) => p switch
                    {
                        "tcp"     => "var(--accent)",
                        "udp"     => "var(--feedback-info-fg)",
                        "tcp+udp" => "var(--feedback-warning-fg)",
                        "icmp"    => "var(--feedback-success-fg)",
                        _         => "var(--surface-fg-muted)"
                    };
                }
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2">
                                <span class="font-mono font-medium">@s.Name</span>
                                @if (s.IsBuiltin)
                                {
                                    <span class="text-[10px] px-1.5 py-0.5 rounded uppercase tracking-wider"
                                          style="background: color-mix(in srgb, var(--surface-fg-muted) 14%, transparent); color: var(--surface-fg-muted);">builtin</span>
                                }
                                @if (s.Members is { Count: > 0 })
                                {
                                    <span class="text-[10px] px-1.5 py-0.5 rounded uppercase tracking-wider"
                                          style="background: color-mix(in srgb, var(--accent) 14%, transparent); color: var(--accent);">group · @s.Members.Count</span>
                                }
                            </div>
                        </td>
                        <td class="px-5 py-3">
                            <span class="badge" style="background: color-mix(in srgb, @ProtoColor(s.Protocol) 14%, transparent); color: @ProtoColor(s.Protocol);">@s.Protocol</span>
                        </td>
                        <td class="px-5 py-3 font-mono text-xs">@s.PortString</td>
                        <td class="px-5 py-3 hidden md:table-cell text-xs" style="color: var(--surface-fg-muted);">@(s.Category ?? "—")</td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs" style="color: var(--surface-fg-muted);">@(s.Description ?? "—")</td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Network/Services/edit/@s.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit @s.Name')">Edit</button>
                                @if (!s.IsBuiltin)
                                {
                                    var msg = $"Delete service '{s.Name}'? Any firewall rules referencing it by name will silently skip the reference at next apply.";
                                    <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                            hx-post="/Network/Services/delete/@s.Id"
                                            hx-trigger="confirmed-del"
                                            data-msg="@msg"
                                            @@click.prevent="(async () => {
                                                const ok = await $store.confirm.ask({
                                                    title: 'Delete service?', message: $event.currentTarget.dataset.msg,
                                                    confirmLabel: 'Delete', level: 'danger'
                                                });
                                                if (ok) htmx.trigger($el, 'confirmed-del');
                                            })()">Delete</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
