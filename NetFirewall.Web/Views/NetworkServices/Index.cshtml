@{
    ViewData["Title"] = "Network — Services";
    Layout = "_Layout";
}
<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);"
     x-data="{ category: '' }">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">Network</p>
        <h1 class="text-2xl font-semibold tracking-tight">Services</h1>
        <p class="text-sm mt-1 text-surface-fg-muted">
            Named L4 catalog (port + protocol). Reference these by name in firewall rule destination ports — change the port once, every rule that uses the service picks it up at next apply.
        </p>
    </div>
    <div class="flex items-center gap-2">
        <label class="text-xs flex items-center gap-2">
            Category
            <select x-model="category"
                    @@change="htmx.trigger(document.getElementById('services-table'), 'manual-refresh')"
                    class="input py-1 text-xs">
                <option value="">All</option>
                @{ var cats = (ViewBag.Categories as List<string?>) ?? new List<string?>(); }
                @foreach (var c in cats) { <option value="@c">@c</option> }
            </select>
        </label>
        <button type="button" class="btn btn-primary"
                hx-get="/Network/Services/edit"
                hx-target="#drawer-body" hx-swap="innerHTML"
                @@click="$store.drawer.openRaw('Add service')">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            Add service
        </button>
    </div>

    <section class="card mt-3 w-full" style="animation: var(--animate-slide-up); animation-delay: 60ms;">
        <div id="services-table"
             hx-get="/Network/Services/table"
             :hx-vals="JSON.stringify({ category })"
             hx-trigger="load, refreshNetworkServices from:body, manual-refresh"
             hx-swap="innerHTML">
            <div class="text-sm py-8 text-center text-surface-fg-muted">Loading…</div>
        </div>
    </section>
</div>
