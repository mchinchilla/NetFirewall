@using NetFirewall.Web.Models
@{
    ViewData["Title"] = "Dashboard";

    var kpis = new[] {
        new KpiCardViewModel {
            Label = "Active leases", Value = "147",
            Delta = "+12", DeltaContext = "since yesterday", Trend = DeltaTrend.Up,
            IconPath = "M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3V6.75a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v4.5a3 3 0 0 1-3 3"
        },
        new KpiCardViewModel {
            Label = "WAN status", Value = "Primary",
            Delta = "●", DeltaContext = "ens192 · 14ms", Trend = DeltaTrend.Up,
            IconPath = "M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z"
        },
        new KpiCardViewModel {
            Label = "Blocked / hr", Value = "3,284",
            Delta = "+18%", DeltaContext = "vs. last hour", Trend = DeltaTrend.Down,
            IconPath = "M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"
        },
        new KpiCardViewModel {
            Label = "Throughput", Value = "428", ValueSuffix = "Mbps",
            Delta = "+24 Mbps", DeltaContext = "peak today", Trend = DeltaTrend.Up,
            IconPath = "M2.25 18 9 11.25l4.306 4.307a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"
        }
    };
}

@* Page header *@
<div class="flex flex-wrap items-end justify-between gap-3 mb-6"
     style="animation: var(--animate-slide-up);">
    <div>
        <p class="text-xs uppercase tracking-wider font-semibold" style="color: var(--surface-fg-muted);">Overview</p>
        <h1 class="text-2xl font-semibold tracking-tight">Network at a glance</h1>
    </div>
    <div class="flex items-center gap-2">
        <button type="button" class="btn btn-ghost"
                @@click="$store.toasts.info('Refreshed network metrics.', 'Sync')">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
            Refresh
        </button>
        <button type="button" class="btn btn-primary"
                @@click="(async () => {
                    const ok = await $store.confirm.ask({
                        title: 'Create snapshot?',
                        message: 'Persists current DHCP/firewall state to /var/lib/netfirewall/snapshots.',
                        confirmLabel: 'Create snapshot',
                        level: 'default'
                    });
                    if (ok) { $store.toasts.success('Snapshot saved.', 'Snapshot created'); }
                })()">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z"/></svg>
            Snapshot
        </button>
    </div>
</div>

@* KPI cards — reused via _KpiCard partial *@
<div class="grid gap-4 grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 mb-6"
     style="animation: var(--animate-slide-up); animation-delay: 60ms;">
    @foreach (var kpi in kpis)
    {
        @await Html.PartialAsync("_KpiCard", kpi)
    }
</div>

@* Two-column area: chart + activity *@
<div class="grid gap-4 grid-cols-1 xl:grid-cols-3 mb-6">
    <section class="card xl:col-span-2" style="animation: var(--animate-slide-up); animation-delay: 120ms;">
        <header class="flex items-center justify-between mb-4">
            <div>
                <h2 class="text-base font-semibold">Traffic — last 24h</h2>
                <p class="text-xs" style="color: var(--surface-fg-muted);">Bandwidth across both WAN interfaces</p>
            </div>
            <div class="flex gap-1 p-1 rounded-md text-xs" style="background-color: var(--surface-muted);">
                <button class="px-2.5 py-1 rounded shadow-sm" style="background-color: var(--surface-elevated);">24h</button>
                <button class="px-2.5 py-1 rounded" style="color: var(--surface-fg-muted);">7d</button>
                <button class="px-2.5 py-1 rounded" style="color: var(--surface-fg-muted);">30d</button>
            </div>
        </header>

        <div class="relative h-56">
            <canvas x-data
                    x-init="$nextTick(() => NetFw.charts.makeTraffic($el, {
                        labels: ['00:00','03:00','06:00','09:00','12:00','15:00','18:00','21:00'],
                        inSeries:  [120, 180, 95, 240, 380, 410, 460, 320],
                        outSeries: [80,  140, 60, 180, 290, 330, 360, 240]
                    }))"></canvas>
        </div>

        <div class="grid grid-cols-3 gap-4 mt-4 text-center text-xs">
            <div><p class="font-semibold text-sm">428 Mbps</p><p style="color: var(--surface-fg-muted);">Avg in</p></div>
            <div><p class="font-semibold text-sm">312 Mbps</p><p style="color: var(--surface-fg-muted);">Avg out</p></div>
            <div><p class="font-semibold text-sm">8.2 TB</p><p style="color: var(--surface-fg-muted);">Today total</p></div>
        </div>
    </section>

    <section class="card" style="animation: var(--animate-slide-up); animation-delay: 180ms;">
        <header class="flex items-center justify-between mb-3">
            <h2 class="text-base font-semibold">Recent activity</h2>
            <a href="#" class="text-xs hover:underline" style="color: var(--accent);">View all</a>
        </header>
        <ol class="relative space-y-4 pl-5">
            <li class="relative">
                <span class="absolute -left-5 top-1 h-3 w-3 rounded-full ring-4" style="background-color: var(--feedback-success-bd); --tw-ring-color: var(--surface-elevated);"></span>
                <p class="text-sm font-medium">DHCP DDNS sync completed</p>
                <p class="text-xs" style="color: var(--surface-fg-muted);">42 records · 3 min ago</p>
            </li>
            <li class="relative">
                <span class="absolute -left-5 top-1 h-3 w-3 rounded-full ring-4" style="background-color: var(--feedback-info-bd); --tw-ring-color: var(--surface-elevated);"></span>
                <p class="text-sm font-medium">Filter rule #87 added</p>
                <p class="text-xs" style="color: var(--surface-fg-muted);">forward · drop · 14 min ago</p>
            </li>
            <li class="relative">
                <span class="absolute -left-5 top-1 h-3 w-3 rounded-full ring-4" style="background-color: var(--feedback-warning-bd); --tw-ring-color: var(--surface-elevated);"></span>
                <p class="text-sm font-medium">WAN failover: primary → secondary</p>
                <p class="text-xs" style="color: var(--surface-fg-muted);">15.4s downtime · 27 min ago</p>
            </li>
            <li class="relative">
                <span class="absolute -left-5 top-1 h-3 w-3 rounded-full ring-4" style="background-color: var(--accent); --tw-ring-color: var(--surface-elevated);"></span>
                <p class="text-sm font-medium">Lease renewed</p>
                <p class="text-xs" style="color: var(--surface-fg-muted);">192.168.10.42 · b8:27:eb:… · 1 h ago</p>
            </li>
        </ol>
    </section>
</div>

@* Subnets table *@
<section class="card" style="animation: var(--animate-slide-up); animation-delay: 240ms;">
    <header class="flex items-center justify-between mb-3">
        <div>
            <h2 class="text-base font-semibold">Subnets &amp; pools</h2>
            <p class="text-xs" style="color: var(--surface-fg-muted);">Lease utilisation per subnet</p>
        </div>
        <button type="button" class="btn btn-ghost text-xs"
                @@click="(async () => {
                    const ok = await $store.confirm.ask({
                        title: 'Release expired leases?',
                        message: 'This will release 12 leases past their end_time. Active clients will renew on next DHCPREQUEST.',
                        confirmLabel: 'Release leases',
                        level: 'warning'
                    });
                    if (ok) { $store.toasts.warning('12 leases released.', 'Cleanup'); }
                })()">
            Release expired
        </button>
    </header>
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Subnet</th>
                    <th class="px-5 py-2 font-medium">Range</th>
                    <th class="px-5 py-2 font-medium">Used</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Utilisation</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var (cidr, range, used, total, pct, status) in new[] {
                    ("192.168.10.0/24", ".10–.250", 87, 240, 36, "ok"),
                    ("192.168.20.0/24", ".10–.200", 154, 190, 81, "warn"),
                    ("10.0.5.0/24",     ".50–.150", 42, 100, 42, "ok"),
                    ("172.16.0.0/22",   ".10–.500", 12, 490, 2,  "ok")
                })
                {
                    <tr class="hover:bg-[color:var(--surface-muted)] transition">
                        <td class="px-5 py-3 font-medium">@cidr</td>
                        <td class="px-5 py-3" style="color: var(--surface-fg-muted);">@range</td>
                        <td class="px-5 py-3">@used / @total</td>
                        <td class="px-5 py-3 hidden md:table-cell">
                            <div class="flex items-center gap-2">
                                <div class="h-1.5 w-32 rounded-full overflow-hidden" style="background-color: var(--surface-muted);">
                                    <div class="h-full rounded-full"
                                         style="width: @(pct)%; background-color: @(status == "warn" ? "var(--feedback-warning-bd)" : "var(--accent)");"></div>
                                </div>
                                <span class="text-xs" style="color: var(--surface-fg-muted);">@(pct)%</span>
                            </div>
                        </td>
                        <td class="px-5 py-3">
                            @if (status == "warn")
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-warning-bg); color: var(--feedback-warning-fg);">Near full</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Healthy</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
