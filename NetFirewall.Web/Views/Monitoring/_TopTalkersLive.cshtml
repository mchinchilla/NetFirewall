@model NetFirewall.Web.Models.Monitoring.TopTalkersLiveViewModel
@{
    static string FmtBytes(long bytes)
    {
        string[] u = ["B", "KB", "MB", "GB", "TB", "PB"];
        var i = 0; var x = (double)bytes;
        while (x >= 1024 && i < u.Length - 1) { x /= 1024; i++; }
        return $"{x:0.##} {u[i]}";
    }

    // Human label for the selected window, used in the panel titles.
    var windowLabel = Model.Range switch
    {
        "1h" => "1h",
        "6h" => "6h",
        "7d" => "7d",
        _ => "24h",
    };
}

@* Window selector. Buttons set the page-level `talkersRange` Alpine var (so the
   30s auto-poll keeps the chosen window) and re-trigger the container fetch.
   Lives inside the swapped partial so the active button reflects server state. *@
<div class="flex items-center justify-end gap-2 mb-3">
    <span class="text-xs text-surface-fg-muted">Window:</span>
    <div class="inline-flex p-1 rounded-md text-xs bg-surface-muted">
        @foreach (var r in NetFirewall.Web.Models.Monitoring.TopTalkersLiveViewModel.Ranges)
        {
            var active = r == Model.Range;
            <button type="button" class="px-2.5 py-1 rounded font-medium transition@(active ? " shadow-sm" : "")"
                    style="@(active ? "background-color: var(--surface-elevated); color: var(--surface-fg);" : "color: var(--surface-fg-muted);")"
                    @(active ? "aria-current=true" : "")
                    @@click="talkersRange = '@r'; htmx.ajax('GET', '/Monitoring/toptalkers?range=@r', { target: $el.closest('.loading-host'), swap: 'innerHTML' })">@r</button>
        }
    </div>
</div>

<div class="grid gap-4 grid-cols-1 xl:grid-cols-2">
    <section class="card">
        <header class="flex items-baseline justify-between mb-3">
            <div>
                <h2 class="text-base font-semibold">Top hosts (@windowLabel)</h2>
                <p class="text-xs text-surface-fg-muted">By total bytes — sampled from conntrack</p>
            </div>
        </header>
        @if (Model.Hosts.Count == 0)
        {
            <p class="text-sm py-6 text-center text-surface-fg-muted">No samples yet. Daemon needs ~30s of warm-up.</p>
        }
        else
        {
            var maxHostBytes = Model.Hosts.Max(h => h.TotalBytes);
            <ul class="space-y-3">
                @foreach (var h in Model.Hosts)
                {
                    var pct = maxHostBytes > 0 ? (double)h.TotalBytes / maxHostBytes * 100 : 0;
                    @* Each host row is an Alpine toggle. Clicking lazily fetches the
                       per-destination drill-down once (loaded flag) and shows/hides it. *@
                    <li x-data="{ open: false, loaded: false }">
                        <button type="button" class="w-full text-left group"
                                @@click="open = !open; if (open && !loaded) { loaded = true; htmx.ajax('GET', '/Monitoring/host-destinations?ip=@Uri.EscapeDataString(h.Label)&range=@Model.Range&hostname=@Uri.EscapeDataString(h.Sublabel ?? "")', { target: $refs.dests, swap: 'innerHTML' }) }">
                            <div class="flex items-baseline justify-between text-sm">
                                <div class="min-w-0 flex items-baseline gap-1.5">
                                    <span class="text-surface-fg-muted transition-transform text-[10px]"
                                          x-bind:class="open ? 'rotate-90' : ''">▶</span>
                                    <span class="font-mono font-medium">@h.Label</span>
                                    @if (!string.IsNullOrEmpty(h.Sublabel))
                                    {
                                        <span class="text-xs text-surface-fg-muted ml-1">@h.Sublabel</span>
                                    }
                                </div>
                                <div class="font-mono text-xs text-surface-fg-muted shrink-0 ml-2">
                                    @* bytes_in is the conntrack forward tuple (LAN→outside = upload);
                                       bytes_out is the reply tuple (outside→LAN = download). Swap for display. *@
                                    ↓ @FmtBytes(h.BytesOut) · ↑ @FmtBytes(h.BytesIn)
                                </div>
                            </div>
                            <div class="h-1.5 mt-1 rounded-full overflow-hidden bg-surface-muted">
                                <div class="h-full rounded-full bg-accent" style="width: @(pct.ToString("0.#"))%;"></div>
                            </div>
                        </button>
                        <div x-show="open" x-cloak x-ref="dests">
                            <p class="text-xs py-3 text-center text-surface-fg-muted">Loading destinations…</p>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>

    <section class="card">
        <header class="flex items-baseline justify-between mb-3">
            <div>
                <h2 class="text-base font-semibold">Top services (@windowLabel)</h2>
                <p class="text-xs text-surface-fg-muted">By total bytes — proto + destination port</p>
            </div>
        </header>
        @if (Model.Services.Count == 0)
        {
            <p class="text-sm py-6 text-center text-surface-fg-muted">No samples yet.</p>
        }
        else
        {
            var maxSvcBytes = Model.Services.Max(s => s.TotalBytes);
            <ul class="space-y-3">
                @foreach (var s in Model.Services)
                {
                    var pct = maxSvcBytes > 0 ? (double)s.TotalBytes / maxSvcBytes * 100 : 0;
                    <li>
                        <div class="flex items-baseline justify-between text-sm">
                            <div class="min-w-0">
                                <span class="font-mono font-medium">@s.Label</span>
                                @if (!string.IsNullOrEmpty(s.Sublabel))
                                {
                                    <span class="text-xs text-surface-fg-muted ml-2">@s.Sublabel</span>
                                }
                            </div>
                            <div class="font-mono text-xs text-surface-fg-muted shrink-0 ml-2">
                                @* See note above: bytes_in = upload, bytes_out = download. Swap for display. *@
                                ↓ @FmtBytes(s.BytesOut) · ↑ @FmtBytes(s.BytesIn)
                            </div>
                        </div>
                        <div class="h-1.5 mt-1 rounded-full overflow-hidden bg-surface-muted">
                            <div class="h-full rounded-full bg-accent" style="width: @(pct.ToString("0.#"))%;"></div>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>
</div>
