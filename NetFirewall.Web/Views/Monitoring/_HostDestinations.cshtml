@model NetFirewall.Web.Models.Monitoring.HostDestinationsViewModel
@{
    static string FmtBytes(long bytes)
    {
        string[] u = ["B", "KB", "MB", "GB", "TB", "PB"];
        var i = 0; var x = (double)bytes;
        while (x >= 1024 && i < u.Length - 1) { x /= 1024; i++; }
        return $"{x:0.##} {u[i]}";
    }
}

<div class="mt-2 ml-2 pl-3 border-l-2" style="border-color: var(--surface-border);">
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="text-xs rounded-md px-3 py-2"
             style="background-color: var(--feedback-danger-bg); color: var(--feedback-danger-fg); border: 1px solid var(--feedback-danger-bd);">
            @Model.Error
        </div>
    }
    else if (Model.Destinations.Count == 0)
    {
        <p class="text-xs py-3 text-center text-surface-fg-muted">No destinations recorded for this host yet.</p>
    }
    else
    {
        var maxBytes = Model.Destinations.Max(d => d.TotalBytes);
        <ul class="space-y-2 py-1">
            @foreach (var d in Model.Destinations)
            {
                var pct = maxBytes > 0 ? (double)d.TotalBytes / maxBytes * 100 : 0;
                <li>
                    <div class="flex items-baseline justify-between text-xs">
                        <div class="min-w-0 flex items-baseline gap-2">
                            @if (d.IsOthers)
                            {
                                <span class="italic text-surface-fg-muted">other destinations</span>
                            }
                            else
                            {
                                <span class="font-mono font-medium">@d.DstIp</span>
                                @if (!string.IsNullOrEmpty(d.Org))
                                {
                                    <span class="px-1.5 py-0.5 rounded text-[10px] font-medium"
                                          style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">
                                        @d.Org@(string.IsNullOrEmpty(d.Country) ? "" : $" · {d.Country}")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-[10px] text-surface-fg-muted">resolving…</span>
                                }
                            }
                        </div>
                        <div class="font-mono text-surface-fg-muted shrink-0 ml-2">
                            @* bytes_in = upload (LAN→outside), bytes_out = download. Swap for display. *@
                            ↓ @FmtBytes(d.BytesOut) · ↑ @FmtBytes(d.BytesIn)
                        </div>
                    </div>
                    <div class="h-1 mt-1 rounded-full overflow-hidden bg-surface-muted">
                        <div class="h-full rounded-full @(d.IsOthers ? "" : "bg-accent")"
                             style="width: @(pct.ToString("0.#"))%;@(d.IsOthers ? " background-color: var(--surface-fg-muted);" : "")"></div>
                    </div>
                </li>
            }
        </ul>
    }
</div>
