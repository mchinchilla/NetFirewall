@{
    ViewData["Title"] = "Monitoring";
    Layout = "_Layout";
}
<div x-data="{ tab: 'live', range: '24h', paused: false }" class="space-y-4"
     style="animation: var(--animate-slide-up);">

    @* ---------- header + tabs ---------- *@
    <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
            <p class="text-xs uppercase tracking-wider font-semibold text-surface-fg-muted">System</p>
            <h1 class="text-2xl font-semibold tracking-tight">Monitoring</h1>
            <p class="text-sm mt-1 text-surface-fg-muted">
                <span x-show="tab === 'live'">Live snapshot from <span class="font-mono">/proc</span> · refreshes every 5s.</span>
                <span x-show="tab === 'history'" x-cloak>Historical samples collected by the daemon every 5s.</span>
            </p>
        </div>

        <div class="inline-flex p-1 rounded-md text-xs bg-surface-muted">
            <button class="px-3 py-1 rounded font-medium transition"
                    :class="tab === 'live'
                        ? 'shadow-sm'
                        : ''"
                    :style="tab === 'live'
                        ? 'background-color: var(--surface-elevated); color: var(--surface-fg);'
                        : 'color: var(--surface-fg-muted);'"
                    @@click="tab = 'live'">Live</button>
            <button class="px-3 py-1 rounded font-medium transition"
                    :class="tab === 'history' ? 'shadow-sm' : ''"
                    :style="tab === 'history'
                        ? 'background-color: var(--surface-elevated); color: var(--surface-fg);'
                        : 'color: var(--surface-fg-muted);'"
                    @@click="tab = 'history'; $nextTick(() => htmx.trigger(document.getElementById('monitoring-history'), 'manual-refresh'))">History</button>
        </div>
    </div>

    @* ---------- Live tab ---------- *@
    <div x-show="tab === 'live'">
        <div class="flex items-center justify-end gap-2 mb-2">
            <button type="button" class="btn btn-ghost text-xs"
                    @@click="paused = !paused"
                    x-text="paused ? 'Resume' : 'Pause'"></button>
            <span class="text-xs text-surface-fg-muted"
                  x-text="paused ? '⏸ Polling paused' : '● Polling every 5s'"></span>
        </div>
        <div id="monitoring-snapshot" class="loading-host"
             hx-get="/Monitoring/snapshot"
             :hx-trigger="paused ? 'load' : 'load, every 5s'"
             hx-swap="innerHTML">
            @await Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder, Size = LoadingOverlaySize.Lg })
        </div>

        @* ---------- Top talkers (refreshed every 30s — daemon's sampler cadence) ---------- *@
        <div id="monitoring-toptalkers" class="mt-4 loading-host"
             hx-get="/Monitoring/toptalkers"
             :hx-trigger="paused ? 'load' : 'load, every 30s'"
             hx-swap="innerHTML">
            @await Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
        </div>

        @* ---------- WireGuard live status (polled at the same cadence) ---------- *@
        <section class="card mt-4">
            <header class="flex items-baseline justify-between mb-3">
                <div>
                    <h2 class="text-base font-semibold">WireGuard peers</h2>
                    <p class="text-xs text-surface-fg-muted">
                        From <span class="font-mono">wg show</span> via the daemon. Empty if no server is configured or the interface isn't up.
                    </p>
                </div>
                <a href="@Url.Action("Index", "WireGuard")" class="text-xs hover:underline text-accent">Manage →</a>
            </header>
            <div id="monitoring-wg" class="loading-host"
                 hx-get="/Vpn/WireGuard/status"
                 :hx-trigger="paused ? 'load' : 'load, every 10s'"
                 hx-swap="innerHTML">
                @await Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
            </div>
        </section>

        @* ---------- Time-based rules (schedules) ---------- *@
        <section class="card mt-4">
            <header class="flex items-baseline justify-between mb-3">
                <div>
                    <h2 class="text-base font-semibold">Active schedules</h2>
                    <p class="text-xs text-surface-fg-muted">
                        The daemon's watcher re-applies the firewall the moment a schedule transitions. Polled every 30s here for visibility.
                    </p>
                </div>
                <a href="@Url.Action("Index", "FwSchedules")" class="text-xs hover:underline text-accent">Manage →</a>
            </header>
            <div id="monitoring-schedules" class="loading-host"
                 hx-get="/Monitoring/schedules"
                 :hx-trigger="paused ? 'load' : 'load, every 30s'"
                 hx-swap="innerHTML">
                @await Html.PartialAsync("_LoadingOverlay", new LoadingOverlayModel { Variant = LoadingOverlayVariant.Placeholder })
            </div>
        </section>
    </div>

    @* ---------- History tab ---------- *@
    <div x-show="tab === 'history'" x-cloak>
        <div class="flex items-center justify-end gap-2 mb-2">
            <span class="text-xs text-surface-fg-muted">Range:</span>
            <div class="inline-flex p-1 rounded-md text-xs bg-surface-muted">
                <template x-for="r in ['1h','6h','24h','7d']" :key="r">
                    <button class="px-2.5 py-1 rounded font-medium transition"
                            :class="range === r ? 'shadow-sm' : ''"
                            :style="range === r
                                ? 'background-color: var(--surface-elevated); color: var(--surface-fg);'
                                : 'color: var(--surface-fg-muted);'"
                            @@click="range = r; htmx.trigger(document.getElementById('monitoring-history'), 'manual-refresh')"
                            x-text="r"></button>
                </template>
            </div>
        </div>
        <div id="monitoring-history" class="loading-host"
             hx-get="/Monitoring/history"
             :hx-vals="JSON.stringify({ range })"
             hx-trigger="manual-refresh"
             hx-swap="innerHTML">
            @await Html.PartialAsync("_LoadingOverlay")
            <div class="text-sm py-10 text-center text-surface-fg-muted">
                Click the History tab to load.
            </div>
        </div>
    </div>
</div>
