@model IReadOnlyList<NetFirewall.Models.Firewall.FwSchedule>
@{
    var attached = (Dictionary<Guid, int>)(ViewBag.Attached ?? new Dictionary<Guid, int>());
    var nowUtc = DateTimeOffset.UtcNow;

    static string FormatDays(int[] dows)
    {
        if (dows.Length == 7) return "Daily";
        if (dows.OrderBy(d => d).SequenceEqual(new[] { 1, 2, 3, 4, 5 })) return "Weekdays";
        if (dows.OrderBy(d => d).SequenceEqual(new[] { 0, 6 })) return "Weekends";
        var names = new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };
        return string.Join(" ", dows.OrderBy(d => d).Select(d => names[d]));
    }
}

@if (Model.Count == 0)
{
    <p class="text-sm py-6 text-center text-surface-fg-muted">
        No schedules configured. <a href="/Firewall/Schedules" class="hover:underline text-accent">Add one →</a>
    </p>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-surface-fg-muted">
                    <th class="px-5 py-2 font-medium">Schedule</th>
                    <th class="px-5 py-2 font-medium">Window</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Days</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Timezone</th>
                    <th class="px-5 py-2 font-medium">Rules</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y border-surface-border">
                @foreach (var s in Model.OrderByDescending(s => s.IsActiveAt(nowUtc)).ThenBy(s => s.Name))
                {
                    var active = s.IsActiveAt(nowUtc);
                    var attachedCount = attached.GetValueOrDefault(s.Id, 0);
                    <tr>
                        <td class="px-5 py-3">
                            <p class="font-medium">@s.Name</p>
                            @if (!string.IsNullOrEmpty(s.Description))
                            {
                                <p class="text-xs text-surface-fg-muted">@s.Description</p>
                            }
                        </td>
                        <td class="px-5 py-3 font-mono text-xs">@s.StartTime.ToString(@"hh\:mm") – @s.EndTime.ToString(@"hh\:mm")</td>
                        <td class="px-5 py-3 hidden md:table-cell text-xs text-surface-fg-muted">@FormatDays(s.DaysOfWeek)</td>
                        <td class="px-5 py-3 hidden lg:table-cell font-mono text-xs text-surface-fg-muted">@s.Timezone</td>
                        <td class="px-5 py-3">
                            @if (attachedCount > 0)
                            {
                                <span class="badge badge-accent">@attachedCount</span>
                            }
                            else
                            {
                                <span class="text-xs text-surface-fg-muted">—</span>
                            }
                        </td>
                        <td class="px-5 py-3">
                            @if (!s.Enabled)
                            {
                                <span class="badge badge-muted">Disabled</span>
                            }
                            else if (active)
                            {
                                <span class="inline-flex items-center gap-1.5 badge badge-success">
                                    <span class="inline-block h-1.5 w-1.5 rounded-full animate-pulse bg-feedback-success-fg"></span>
                                    Active now
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-muted">Idle</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
