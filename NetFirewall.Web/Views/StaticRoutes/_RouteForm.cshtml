@model NetFirewall.Web.Models.Network.StaticRouteFormViewModel
@using NetFirewall.Web.Models
@using NetFirewall.Web.Models.Network
@{
    var ifaces = (IReadOnlyList<NetFirewall.Models.Firewall.FwInterface>)(ViewBag.Interfaces ?? Array.Empty<NetFirewall.Models.Firewall.FwInterface>());
    var ifaceOptions = ifaces.Select(i => new FormFieldViewModel.SelectOption(
        i.Id.ToString(), $"{i.Name} ({i.Type})", i.Id == Model.InterfaceId)).ToList();
    if (ifaceOptions.Count == 0)
    {
        ifaceOptions.Add(new FormFieldViewModel.SelectOption("", "(no interfaces configured yet)"));
    }
}
<form id="route-form"
      hx-post="/Network/Routes/save"
      hx-target="this"
      hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    @if (Model.Id.HasValue)
    {
        <input type="hidden" name="Id" value="@Model.Id" />
    }

    <div class="space-y-4">
        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = "InterfaceId",
            Label = "Interface",
            Kind = FormFieldKind.Select,
            Required = true,
            Value = Model.InterfaceId.ToString(),
            Help = "Routes are bound to a NetFirewall-managed interface.",
            Options = ifaceOptions
        })

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = "Destination",
            Label = "Destination CIDR",
            Required = true,
            Value = Model.Destination,
            Placeholder = "10.0.0.0/8",
            Pattern = @"^(\d{1,3}\.){3}\d{1,3}/\d{1,2}$",
            Help = "IPv4 only. Use 0.0.0.0/0 for the default route."
        })

        <div class="grid grid-cols-2 gap-3">
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = "Gateway",
                Label = "Gateway",
                Value = Model.Gateway,
                Placeholder = "192.168.1.1",
                Help = "Leave empty for a directly-connected route."
            })
            @await Html.PartialAsync("_FormField", new FormFieldViewModel {
                Name = "Metric",
                Label = "Metric",
                Kind = FormFieldKind.Number,
                Value = Model.Metric.ToString(),
                Min = "0", Max = "1024", Required = true
            })
        </div>

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = "Description",
            Label = "Description",
            Kind = FormFieldKind.Textarea,
            Value = Model.Description
        })

        @await Html.PartialAsync("_FormField", new FormFieldViewModel {
            Name = "Enabled",
            Label = "Enabled (uncheck to keep the route in DB but skip generating it)",
            Kind = FormFieldKind.Checkbox,
            Value = Model.Enabled ? "true" : "false"
        })
    </div>

    <div class="mt-6 pt-4 border-t flex items-center justify-end gap-2"
         style="border-color: var(--surface-border);">
        <button type="button" class="btn btn-ghost" @@click="$store.drawer.close()">Cancel</button>
        <button type="submit" class="btn btn-primary">@(Model.Id.HasValue ? "Save changes" : "Create route")</button>
    </div>
</form>
