@model IReadOnlyList<NetFirewall.Web.Models.Network.InterfaceRowViewModel>
@using NetFirewall.Web.Models.Network

@if (Model.Count == 0)
{
    <div class="text-sm py-8 text-center" style="color: var(--surface-fg-muted);">
        No network interfaces detected. Re-detect, or check that the host has at least one NIC.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Interface</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium">Role</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">IP</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">MAC</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var row in Model)
                {
                    <tr>
                        <td class="px-5 py-3 align-top">
                            <div class="flex items-center gap-2">
                                <span class="relative flex h-2 w-2">
                                    @if (row.IsUp)
                                    {
                                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-60" style="background-color: var(--feedback-success-bd);"></span>
                                        <span class="relative inline-flex rounded-full h-2 w-2" style="background-color: var(--feedback-success-bd);"></span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex rounded-full h-2 w-2" style="background-color: var(--surface-fg-muted);"></span>
                                    }
                                </span>
                                <span class="font-medium">@row.Name</span>
                                @if (row.IsVirtual)
                                {
                                    <span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded"
                                          style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">virtual</span>
                                }
                            </div>
                            @if (row.Configured == null)
                            {
                                <p class="text-xs mt-0.5" style="color: var(--surface-fg-muted);">
                                    Suggested:
                                    <span class="font-medium" style="color: var(--surface-fg);">@row.SuggestedType</span>
                                    <span class="opacity-70">· @row.SuggestionConfidence% confidence</span>
                                </p>
                            }
                        </td>
                        <td class="px-5 py-3 align-top">
                            @switch (row.Status)
                            {
                                case InterfaceRowStatus.Configured:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                          style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Configured</span>
                                    break;
                                case InterfaceRowStatus.Detected:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                          style="background-color: var(--feedback-info-bg); color: var(--feedback-info-fg);">Detected</span>
                                    break;
                                case InterfaceRowStatus.Missing:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                          style="background-color: var(--feedback-warning-bg); color: var(--feedback-warning-fg);">Missing</span>
                                    break;
                            }
                        </td>
                        <td class="px-5 py-3 align-top">
                            @if (row.Configured != null)
                            {
                                <span class="font-medium">@row.Configured.Type</span>
                                @if (!string.IsNullOrEmpty(row.Configured.Role))
                                {
                                    <span class="text-xs ml-1" style="color: var(--surface-fg-muted);">/ @row.Configured.Role</span>
                                }
                            }
                            else
                            {
                                <span style="color: var(--surface-fg-muted);">—</span>
                            }
                        </td>
                        <td class="px-5 py-3 hidden md:table-cell align-top font-mono text-xs">
                            @if (row.Configured != null)
                            {
                                @(row.Configured.AddressingMode == "dhcp" ? "DHCP" : row.Configured.IpAddress?.ToString() ?? "—")
                            }
                            else
                            {
                                @(row.CurrentIp ?? "—")
                            }
                        </td>
                        <td class="px-5 py-3 hidden lg:table-cell align-top font-mono text-xs" style="color: var(--surface-fg-muted);">
                            @(row.MacAddress ?? "—")
                        </td>
                        <td class="px-5 py-3 align-top text-right">
                            <button type="button" class="btn btn-ghost text-xs"
                                    hx-get="/Network/Edit/@row.Name"
                                    hx-target="#drawer-body"
                                    hx-swap="innerHTML"
                                    @@click="$store.drawer.openRaw('@(row.Configured == null ? "Configure" : "Edit") @row.Name')">
                                @(row.Configured == null ? "Configure" : "Edit")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
