@model IReadOnlyList<NetFirewall.Models.Vpn.WgPeer>
@{
    var mode = (string?)ViewData["wg.mode"] ?? "server";
    var isClient = string.Equals(mode, "client", StringComparison.OrdinalIgnoreCase);
    var emptyMsg = isClient
        ? "No remote server set — click Set remote server to define the upstream tunnel."
        : "No peers yet — click Add peer.";
}

@if (Model.Count == 0)
{
    <p class="text-sm py-10 text-center text-surface-fg-muted">@emptyMsg</p>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-surface-fg-muted">
                    <th class="px-5 py-2 font-medium">Name</th>
                    <th class="px-5 py-2 font-medium">@(isClient ? "Routed via tunnel" : "Allowed IPs")</th>
                    @if (!isClient)
                    {
                        <th class="px-5 py-2 font-medium hidden lg:table-cell">Access</th>
                    }
                    else
                    {
                        <th class="px-5 py-2 font-medium hidden lg:table-cell">Endpoint</th>
                    }
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Public key</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y border-surface-border">
                @foreach (var p in Model.OrderBy(p => p.Name))
                {
                    <tr>
                        <td class="px-5 py-3 font-medium">
                            @p.Name
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <p class="text-xs font-normal text-surface-fg-muted">@p.Description</p>
                            }
                        </td>
                        <td class="px-5 py-3 font-mono text-xs">@string.Join(", ", p.AllowedIps)</td>
                        @if (!isClient)
                        {
                            <td class="px-5 py-3 hidden lg:table-cell text-xs">
                                <span class="badge badge-muted">@(string.IsNullOrEmpty(p.RouteMode) ? "full" : p.RouteMode)</span>
                            </td>
                        }
                        else
                        {
                            <td class="px-5 py-3 hidden lg:table-cell font-mono text-xs text-surface-fg-muted">@(p.Endpoint ?? "—")</td>
                        }
                        <td class="px-5 py-3 hidden md:table-cell font-mono text-xs text-surface-fg-muted" title="@p.PublicKey">@p.PublicKey[..12]…</td>
                        <td class="px-5 py-3">
                            @if (p.Enabled)
                            {
                                <span class="badge badge-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge badge-muted">Disabled</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Vpn/WireGuard/Peers/edit/@p.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit @p.Name')">Edit</button>
                                @{ var msg = $"Delete peer '{p.Name}'? Their client config will stop working — there's no way to recover the private key, you'd have to issue a new peer."; }
                                <button type="button" class="btn btn-ghost text-xs text-feedback-danger-fg"
                                        hx-post="/Vpn/WireGuard/Peers/delete/@p.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete peer?', message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete', level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
