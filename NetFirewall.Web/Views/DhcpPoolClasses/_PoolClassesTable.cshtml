@model IReadOnlyList<NetFirewall.Models.Dhcp.DhcpClass>
@{
    var bindings = (Dictionary<Guid, bool>)(ViewBag.Bindings ?? new Dictionary<Guid, bool>());
    var poolId = (Guid)ViewBag.PoolId;
}

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center text-surface-fg-muted">
        No client classes defined yet. Create some under
        <a class="hover:underline text-accent" href="@Url.Action("Index", "DhcpClasses")">DHCP → Classes</a>
        first.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider text-surface-fg-muted">
                    <th class="px-5 py-2 font-medium">Class</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Match</th>
                    <th class="px-5 py-2 font-medium">Binding</th>
                    <th class="px-5 py-2 font-medium text-right">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y border-surface-border">
                @foreach (var c in Model.OrderBy(c => c.Priority).ThenBy(c => c.Name))
                {
                    var hasBinding = bindings.TryGetValue(c.Id, out var allow);
                    string state, label, fg;
                    if (!hasBinding)
                    {
                        state = "unbound"; label = "unbound";
                        fg = "var(--surface-fg-muted)";
                    }
                    else if (allow)
                    {
                        state = "allow"; label = "allowed";
                        fg = "var(--feedback-success-fg)";
                    }
                    else
                    {
                        state = "deny"; label = "denied";
                        fg = "var(--feedback-danger-fg)";
                    }

                    <tr>
                        <td class="px-5 py-3">
                            <p class="font-medium">@c.Name</p>
                            <p class="text-xs text-surface-fg-muted">priority @c.Priority @(c.Enabled ? "" : "· disabled")</p>
                        </td>
                        <td class="px-5 py-3 hidden md:table-cell font-mono text-xs text-surface-fg-muted">
                            @c.MatchType <span class="text-surface-border">·</span> @c.MatchValue
                        </td>
                        <td class="px-5 py-3">
                            <span class="badge" style="background: color-mix(in srgb, @fg 14%, transparent); color: @fg;">@label</span>
                        </td>
                        <td class="px-5 py-3 text-right">
                            <form class="inline-flex items-center gap-1"
                                  hx-post="/Dhcp/Subnets/@ViewBag.SubnetId/Pools/@poolId/Classes/set"
                                  hx-swap="none">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="classId" value="@c.Id" />
                                <button type="submit" name="mode" value="allow"
                                        class="btn btn-ghost text-xs"
                                        style="@(state == "allow" ? "color: var(--feedback-success-fg); font-weight: 600;" : "")">Allow</button>
                                <button type="submit" name="mode" value="deny"
                                        class="btn btn-ghost text-xs"
                                        style="@(state == "deny" ? "color: var(--feedback-danger-fg); font-weight: 600;" : "")">Deny</button>
                                @if (hasBinding)
                                {
                                    <button type="submit" name="mode" value="remove"
                                            class="btn btn-ghost text-xs text-surface-fg-muted">Unbind</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
