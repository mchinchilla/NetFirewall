@model IReadOnlyList<NetFirewall.Models.Dhcp.DdnsConfig>
@{
    var subnetNames = (IDictionary<Guid, string>)(ViewBag.SubnetNames ?? new Dictionary<Guid, string>());
}

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">
        No DDNS configs yet. Add a global config (no subnet binding) or one per subnet to override.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">Scope</th>
                    <th class="px-5 py-2 font-medium">Forward zone</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">DNS server</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">TSIG</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var d in Model.OrderBy(x => x.SubnetId is null ? "" : (subnetNames.TryGetValue(x.SubnetId.Value, out var n) ? n : "?")))
                {
                    var scope = d.SubnetId is null
                        ? "Global"
                        : (subnetNames.TryGetValue(d.SubnetId.Value, out var n) ? n : "(unknown subnet)");
                    <tr>
                        <td class="px-5 py-3">
                            @if (d.SubnetId is null)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium"
                                      style="background-color: var(--accent-soft); color: var(--accent);">Global</span>
                            }
                            else
                            {
                                <span class="font-medium">@scope</span>
                            }
                        </td>
                        <td class="px-5 py-3 font-mono text-xs">@(d.ForwardZone ?? "—")</td>
                        <td class="px-5 py-3 hidden md:table-cell font-mono text-xs">@d.DnsServer:@d.DnsPort</td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs" style="color: var(--surface-fg-muted);">
                            @(string.IsNullOrEmpty(d.TsigKeyName) ? "(no key)" : $"{d.TsigKeyName} · {d.TsigAlgorithm}")
                        </td>
                        <td class="px-5 py-3">
                            @if (d.Enabled)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Enabled</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">Disabled</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            <div class="inline-flex items-center gap-1">
                                <button type="button" class="btn btn-ghost text-xs"
                                        hx-get="/Dhcp/Ddns/edit/@d.Id"
                                        hx-target="#drawer-body" hx-swap="innerHTML"
                                        @@click="$store.drawer.openRaw('Edit DDNS config')">Edit</button>
                                @{ var msg = $"Delete DDNS config for {scope}? Future leases will fall back to the next config in scope (or stop updating DNS)."; }
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Dhcp/Ddns/delete/@d.Id"
                                        hx-trigger="confirmed-del"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Delete DDNS config?',
                                                message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Delete',
                                                level: 'danger'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-del');
                                        })()">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
