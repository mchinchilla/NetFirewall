@model IReadOnlyList<NetFirewall.Models.Dhcp.DhcpLease>
@{
    var includeExpired = (bool)(ViewBag.IncludeExpired ?? false);
    var now = DateTime.UtcNow;
}

@if (Model.Count == 0)
{
    <div class="text-sm py-10 text-center" style="color: var(--surface-fg-muted);">
        No @(includeExpired ? "leases on record" : "active leases").
        Plug something in and watch this page repaint.
    </div>
}
else
{
    <div class="overflow-x-auto -mx-5">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs uppercase tracking-wider" style="color: var(--surface-fg-muted);">
                    <th class="px-5 py-2 font-medium">IP</th>
                    <th class="px-5 py-2 font-medium">MAC</th>
                    <th class="px-5 py-2 font-medium hidden md:table-cell">Hostname</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Issued</th>
                    <th class="px-5 py-2 font-medium hidden lg:table-cell">Expires</th>
                    <th class="px-5 py-2 font-medium">Status</th>
                    <th class="px-5 py-2 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y" style="border-color: var(--surface-border);">
                @foreach (var l in Model.OrderBy(x => x.IpAddress?.ToString()))
                {
                    var expired = l.EndTime <= now;
                    var remaining = l.EndTime - now;
                    <tr>
                        <td class="px-5 py-3 font-mono text-xs font-medium">@l.IpAddress</td>
                        <td class="px-5 py-3 font-mono text-xs">@l.MacAddress</td>
                        <td class="px-5 py-3 hidden md:table-cell text-xs">@(l.Hostname ?? "—")</td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs" style="color: var(--surface-fg-muted);">
                            @l.StartTime.ToLocalTime().ToString("g")
                        </td>
                        <td class="px-5 py-3 hidden lg:table-cell text-xs" style="color: var(--surface-fg-muted);">
                            @l.EndTime.ToLocalTime().ToString("g")
                            @if (!expired && remaining.TotalHours < 24)
                            {
                                <span class="ml-1 text-[10px]" style="color: var(--feedback-warning-bd);">(in @remaining.Hours h @remaining.Minutes m)</span>
                            }
                        </td>
                        <td class="px-5 py-3">
                            @if (expired)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--surface-muted); color: var(--surface-fg-muted);">Expired</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: var(--feedback-success-bg); color: var(--feedback-success-fg);">Active</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-right">
                            @if (!expired)
                            {
                                var msg = $"Release lease {l.IpAddress} (MAC {l.MacAddress})? The client will need to renew via DHCPREQUEST.";
                                <button type="button" class="btn btn-ghost text-xs" style="color: var(--feedback-danger-fg);"
                                        hx-post="/Dhcp/Leases/release/@l.Id"
                                        hx-trigger="confirmed-rel"
                                        data-msg="@msg"
                                        @@click.prevent="(async () => {
                                            const ok = await $store.confirm.ask({
                                                title: 'Release lease?',
                                                message: $event.currentTarget.dataset.msg,
                                                confirmLabel: 'Release',
                                                level: 'warning'
                                            });
                                            if (ok) htmx.trigger($el, 'confirmed-rel');
                                        })()">Release</button>
                            }
                            else
                            {
                                <span class="text-xs" style="color: var(--surface-fg-muted);">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
